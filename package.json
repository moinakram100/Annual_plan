{
  "name": "Annual_plan",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4.5.1",
    "@sap/cds": "^9",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-annualplan": "cds watch --open com.ingenx.annualplan/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "cds": {
    "requires": {
      "GMSANNUALPLANNING_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/GMSANNUALPLANNING_SRV",
        "[production]": {
          "credentials": {
            "destination": "Ingenx_OData_2023",
            "path": "/sap/opu/odata/gms/ANNUALPLANNING_SRV"
          }
        },
        "[development]": {
          "credentials": {
            "destination": "SandboxPO_2023",
            "path": "/sap/opu/odata/gms/ANNUALPLANNING_SRV"
          }
        },
        "csrf": true,
        "csrfInBatch": true
      }
    }
  }
}