<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <SelectDialog
        id="contractVHDialog"
        title="Select Contract"
        search=".onContractVHSearch"
        liveChange=".onContractVHSearch"
        confirm=".onContractVHConfirm"
        cancel=".onContractVHCancel"
        growing="true"
        growingThreshold="20"
        items="{ap>/contractList}">
        <StandardListItem
            title="{ap>ContractNo}"
            description="Material: {ap>Material}"
            icon="sap-icon://document-text"
            type="Active"/>
    </SelectDialog>
</core:FragmentDefinition>