<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <SelectDialog
        id="materialVHDialog"
        title="Select Material"
        search=".onMaterialVHSearch"
        liveChange=".onMaterialVHSearch"
        confirm=".onMaterialVHConfirm"
        growing="true"
        growingThreshold="20"
        cancel=".onMaterialVHCancel"
        items="{
            path: '/xGMSxAP_MATERIAL',
            templateShareable: false
        }">

        <StandardListItem
            title="{Material}"
            description="{MaterialDesc}"
            info="{MaterialType}"
            icon="sap-icon://product"
            type="Active"
            />

    </SelectDialog>

</core:FragmentDefinition>