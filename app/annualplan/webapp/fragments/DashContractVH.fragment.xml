<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <SelectDialog
        id="dashContractVHDialog"
        title="Select Contract"
        search=".onDashContractVHSearch"
        liveChange=".onDashContractVHSearch"
        confirm=".onDashContractVHConfirm"
        cancel=".onDashContractVHCancel"
        growing="true"
        growingThreshold="20"
        items="{dash>/dashContractList}">

        <StandardListItem
            title="{dash>ContractNo}"
            description="Material: {dash>Material}"
            icon="sap-icon://document-text"
            type="Active"/>

    </SelectDialog>

</core:FragmentDefinition>