<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">

    <Dialog
        id="editPlanDialog"
        title="Edit Monthly Plan"
        contentWidth="980px"
        resizable="true"
        draggable="true"
        class="editPlanDialogCustom">

        <customHeader>
            <Bar>
                <contentLeft>
                    <HBox>
                        <Title text="Edit Monthly Plan " level="H4"/>
                        <Text text="{edit>/customer}" class="sapUiTinyMargin"/>
                    </HBox>
                </contentLeft>
                <contentMiddle>
                    <HBox alignItems="Center" justifyContent="Center">
                        <core:Icon src="sap-icon://locked" color="#0070f2" class="sapUiSmallMarginEnd"/>
                        <Text text="AACQ locked at {edit>/aacq} {edit>/uom}"/>
                    </HBox>
                </contentMiddle>
                <contentRight>
                    <ObjectStatus
                        title="Annual Total"
                        text="{edit>/editAnnualTotal} {edit>/uom}"
                        state="{= ${edit>/editAnnualTotal} === ${edit>/aacq} ? 'Success' : 'Error'}"
                        icon="{= ${edit>/editAnnualTotal} === ${edit>/aacq} ? 'sap-icon://sys-enter-2' : 'sap-icon://alert'}"/>
                </contentRight>
            </Bar>
        </customHeader>

        <content>
            <VBox class="sapUiSmallMargin">

                <!-- Summary Strip -->
                <HBox justifyContent="SpaceBetween" class="sapUiSmallMarginBottom" alignItems="Center">
                    <HBox alignItems="Center">
                        <ObjectStatus title="Q1" text="{edit>/q1Total}" state="{edit>/q1State}" class="sapUiSmallMarginEnd"/>
                        <ObjectStatus title="Q2" text="{edit>/q2Total}" state="{edit>/q2State}" class="sapUiSmallMarginEnd"/>
                        <ObjectStatus title="Q3" text="{edit>/q3Total}" state="{edit>/q3State}" class="sapUiSmallMarginEnd"/>
                        <ObjectStatus title="Q4" text="{edit>/q4Total}" state="{edit>/q4State}"/>
                    </HBox>
                    <MessageStrip
                        text="{= ${edit>/editAnnualTotal} === ${edit>/aacq} ? 'Annual total matches AACQ \u2713' : 'Difference: ' + (${edit>/editAnnualTotal} - ${edit>/aacq}) + ' ' + ${edit>/uom}}"
                        type="{= ${edit>/editAnnualTotal} === ${edit>/aacq} ? 'Success' : 'Error'}"
                        showIcon="true"
                        class="sapUiNoMargin"/>
                </HBox>

                <!-- Grid of all 4 quarters -->
                <l:Grid defaultSpan="XL6 L6 M12 S12" class="sapUiNoMarginTop">
                    <l:content>

                        <!-- Q1 Card -->
                        <VBox class="editQtrCard sapUiSmallMarginEnd sapUiSmallMarginBottom">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="editQtrHeader sapUiSmallMarginBottom">
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://calendar" class="sapUiTinyMarginEnd" color="#0070f2"/>
                                    <Title text="Q1 — Jan · Feb · Mar" level="H5"/>
                                </HBox>
                                <HBox alignItems="Center">
                                    <ObjectStatus text="{edit>/q1Total}" state="{edit>/q1State}" class="sapUiSmallMarginEnd"/>
                                    <Text text="/ {edit>/quarterlyLimits/q1Limit}% limit" class="sapUiTinyText"/>
                                </HBox>
                            </HBox>
                            <HBox wrap="Wrap">
                                <VBox class="editMonthBox sapUiSmallMarginEnd">
                                    <Label text="January" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/jan}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                                <VBox class="editMonthBox sapUiSmallMarginEnd">
                                    <Label text="February" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/feb}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                                <VBox class="editMonthBox">
                                    <Label text="March" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/mar}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Q2 Card -->
                        <VBox class="editQtrCard sapUiSmallMarginBottom">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="editQtrHeader sapUiSmallMarginBottom">
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://calendar" class="sapUiTinyMarginEnd" color="#e9730c"/>
                                    <Title text="Q2 — Apr · May · Jun" level="H5"/>
                                </HBox>
                                <HBox alignItems="Center">
                                    <ObjectStatus text="{edit>/q2Total}" state="{edit>/q2State}" class="sapUiSmallMarginEnd"/>
                                    <Text text="/ {edit>/quarterlyLimits/q2Limit}% limit" class="sapUiTinyText"/>
                                </HBox>
                            </HBox>
                            <HBox wrap="Wrap">
                                <VBox class="editMonthBox sapUiSmallMarginEnd">
                                    <Label text="April" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/apr}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                                <VBox class="editMonthBox sapUiSmallMarginEnd">
                                    <Label text="May" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/may}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                                <VBox class="editMonthBox">
                                    <Label text="June" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/jun}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Q3 Card -->
                        <VBox class="editQtrCard sapUiSmallMarginEnd sapUiSmallMarginBottom">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="editQtrHeader sapUiSmallMarginBottom">
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://calendar" class="sapUiTinyMarginEnd" color="#188918"/>
                                    <Title text="Q3 — Jul · Aug · Sep" level="H5"/>
                                </HBox>
                                <HBox alignItems="Center">
                                    <ObjectStatus text="{edit>/q3Total}" state="{edit>/q3State}" class="sapUiSmallMarginEnd"/>
                                    <Text text="/ {edit>/quarterlyLimits/q3Limit}% limit" class="sapUiTinyText"/>
                                </HBox>
                            </HBox>
                            <HBox wrap="Wrap">
                                <VBox class="editMonthBox sapUiSmallMarginEnd">
                                    <Label text="July" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/jul}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                                <VBox class="editMonthBox sapUiSmallMarginEnd">
                                    <Label text="August" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/aug}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                                <VBox class="editMonthBox">
                                    <Label text="September" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/sep}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Q4 Card -->
                        <VBox class="editQtrCard sapUiSmallMarginBottom">
                            <HBox justifyContent="SpaceBetween" alignItems="Center" class="editQtrHeader sapUiSmallMarginBottom">
                                <HBox alignItems="Center">
                                    <core:Icon src="sap-icon://calendar" class="sapUiTinyMarginEnd" color="#bb0000"/>
                                    <Title text="Q4 — Oct · Nov · Dec" level="H5"/>
                                </HBox>
                                <HBox alignItems="Center">
                                    <ObjectStatus text="{edit>/q4Total}" state="{edit>/q4State}" class="sapUiSmallMarginEnd"/>
                                    <Text text="/ {edit>/quarterlyLimits/q4Limit}% limit" class="sapUiTinyText"/>
                                </HBox>
                            </HBox>
                            <HBox wrap="Wrap">
                                <VBox class="editMonthBox sapUiSmallMarginEnd">
                                    <Label text="October" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/oct}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                                <VBox class="editMonthBox sapUiSmallMarginEnd">
                                    <Label text="November" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/nov}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                                <VBox class="editMonthBox">
                                    <Label text="December" design="Bold" class="editMonthLabel"/>
                                    <Input type="Number" value="{edit>/monthlyPlan/dec}" liveChange=".onEditMonthChange" class="editMonthInput"/>
                                </VBox>
                            </HBox>
                        </VBox>

                    </l:content>
                </l:Grid>

            </VBox>
        </content>

        <beginButton>
            <Button text="Save Changes" type="Emphasized" icon="sap-icon://save" press=".onSaveEditedPlan"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" type="Ghost" press=".onCancelEditPlan"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>