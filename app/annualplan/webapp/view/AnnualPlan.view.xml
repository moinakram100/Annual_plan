<mvc:View
    controllerName="com.ingenx.annualplan.controller.AnnualPlan"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    xmlns:table="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:tnt="sap.tnt"
    displayBlock="true">

    <Page showHeader="false">
  

        <!-- tool header -->
         <tnt:ToolHeader id="annualPlan__toolheader" class="sapUiTinyMargin header_nav">
            <Title id="annualPlan_Title" textAlign="Center" text="Annual Plan Submission" wrapping="false">
                <layoutData>
                    <OverflowToolbarLayoutData id="annualPlan_OverflowToolbarLayoutData" priority="Disappear" />
                </layoutData>
            </Title>
            <ToolbarSpacer id="annualPlan_ToolbarSpacer" />
        </tnt:ToolHeader>

        <!-- filter Bar -->
        <HBox class="filterArea">
             <HBox class="headerSelectArea">
                 <VBox>
                     <Label id="_IDGenLabel1" text="Calendar Year" design="Bold" width="100px"/>
                        <Select
                            id="selYear"
                            width="200px"
                            selectedKey="{ap>/contractSelection/calendarYear}"
                            change=".onSelectionChange">
                            <items>
                                <core:Item id="_IDGenItem" key="2024" text="2024"/>
                                <core:Item id="_IDGenItem1" key="2025" text="2025"/>
                                <core:Item id="_IDGenItem2" key="2026" text="2026"/>
                                <core:Item id="_IDGenItem3" key="2027" text="2027"/>
                            </items>
                        </Select>
                 </VBox>

                 <VBox class="sapUiTinyMarginBegin"> 
                      <Label id="_IDGenLabel11" text="Customer ID" design="Bold" width="90px"/>
                        <Input
                            id="inputCustomerId"
                            value="{ap>/contractSelection/customerId}"
                            placeholder="e.g. CUST-1001"
                            width="200px"
                            showValueHelp="true"
                            valueHelpRequest=".onCustomerVH"
                            change=".onSelectionChange"/>
                 </VBox>

                 <VBox class="sapUiTinyMarginBegin">
                            <Label id="_IDGenLabel38" text="Contract No." design="Bold" width="90px"/>
                        <Select
                            id="selContract"
                            width="200px"
                            selectedKey="{ap>/contractSelection/contractNumber}"
                            change=".onContractChange">
                            <items>
                                <core:Item id="_IDGenItem4" key="" text="Select Contract…"/>
                                <core:Item id="_IDGenItem5" key="CTR-2025-001" text="CTR-2025-001 (RLNG)"/>
                                <core:Item id="_IDGenItem6" key="CTR-2025-008" text="CTR-2025-008 (PNG)"/>
                            </items>
                        </Select>
                 </VBox>

                 <VBox>
                    <Label text=""/>
                     <HBox>
                          <Button id="_IDGenButton6"
                            text="Go"
                            type="Emphasized"
                            class="sapUiTinyMarginBegin"
                            press=".onLoadContract"/>
                        <Button id="_IDGenButton7"
                            text="Clear"
                            type="Ghost"
                            press=".onClearAll"
                            class="sapUiTinyMarginBegin"/>
                     </HBox>
                 </VBox>
                 <ToolbarSpacer width="200px"/>
                 <VBox>
                     <Label text=""/>
                     <HBox>
                           <Button id="_IDGenButton3"
                        text="Save Draft"
                        icon="sap-icon://save"
                        type="Ghost"
                        enabled="{ap>/ui/hasChanges}"
                        press=".onSaveDraft"
                        visible="{ap>/ui/contractSelected}"/>
                    <Button id="_IDGenButton4"
                        text="Reset"
                        icon="sap-icon://undo"
                        type="Ghost"
                        enabled="{ap>/ui/hasChanges}"
                        press=".onReset"
                        class="sapUiTinyMarginBegin"
                        visible="{ap>/ui/contractSelected}"/>
                    <Button id="_IDGenButton5"
                        text="Submit Plan"
                        icon="sap-icon://paper-plane"
                        type="Emphasized"
                        class="sapUiTinyMarginBegin"
                        enabled="{ap>/ui/submitEnabled}"
                        press=".onSubmitPlan"
                        visible="{ap>/ui/contractSelected}"/>
                     </HBox>
                 </VBox>
             </HBox>
        </HBox>

        <!-- contract details content -->
         <VBox class="filterArea sapUiSmallMarginTop annualPlanArea"  visible="{ap>/ui/contractSelected}">
           <Panel
                        id="contractInfoPanel"
                        backgroundDesign="Solid"
                        class="sapUiSmallMarginTop">

                        <content>
                            <!-- Row 1: Main contract header -->
                            <ObjectHeader
                                id="contractHeader"
                                title="{ap>/selectedContract/customerDesc}"
                                number="{ap>/selectedContract/aacq}"
                                numberUnit="{ap>/selectedContract/uom}"
                                intro="{ap>/selectedContract/contractNumber} · {ap>/selectedContract/material}"
                                backgroundDesign="Solid">
                                <attributes>
                                    <ObjectAttribute id="_IDGenObjectAttribute3" title="Sales Office"  text="{ap>/selectedContract/salesOffice}"/>
                                    <ObjectAttribute id="_IDGenObjectAttribute4" title="Valid Period"  text="{ap>/selectedContract/validFrom} – {ap>/selectedContract/validTo}"/>
                                    <ObjectAttribute id="_IDGenObjectAttribute5" title="TOP %"        text="{ap>/selectedContract/topPercent}%"/>
                                </attributes>
                                <statuses>
                                    <ObjectStatus id="_IDGenObjectStatus16"
                                        title="Contract Status"
                                        text="{ap>/selectedContract/status}"
                                        state="Success"
                                        icon="sap-icon://accept"/>
                                    <!-- <ObjectStatus
                                        title="S/D Days Remaining"
                                        text="{ap>/ui/sdDaysRemaining} days"
                                        state="{= ${ap>/ui/sdDaysRemaining} <= 3 ? 'Error' :
                                                   ${ap>/ui/sdDaysRemaining} <= 7 ? 'Warning' : 'Success'}"/> -->
                                </statuses>
                            </ObjectHeader>

                            <!-- Row 2: Contract fields grid -->
                            <l:Grid id="_IDGenGrid1"
                                defaultSpan="XL2 L2 M4 S6"
                                class="sapUiSmallMarginBegin sapUiSmallMarginBottom">
                                <l:content>
                                    <VBox id="_IDGenVBox4">
                                        <Label id="_IDGenLabel39" text="ACQ" design="Bold"/>
                                        <ObjectNumber id="_IDGenObjectNumber"
                                            number="{ap>/selectedContract/acq}"
                                            unit="{ap>/selectedContract/uom}"
                                            emphasized="false"/>
                                    </VBox>
                                    <VBox id="_IDGenVBox5">
                                        <Label id="_IDGenLabel40" text="AACQ (Calculated)" design="Bold"/>
                                        <ObjectNumber id="_IDGenObjectNumber2"
                                            number="{ap>/selectedContract/aacq}"
                                            unit="{ap>/selectedContract/uom}"
                                            emphasized="true"
                                            state="Information"/>
                                    </VBox>
                                    <VBox id="_IDGenVBox8">
                                        <Label id="_IDGenLabel41" text="Upward Flex %" design="Bold"/>
                                        <Text id="_IDGenText1" text="+{ap>/selectedContract/upwardFlex}%"/>
                                    </VBox>
                                    <VBox id="_IDGenVBox9">
                                        <Label id="_IDGenLabel42" text="Downward Flex %" design="Bold"/>
                                        <Text id="_IDGenText2" text="-{ap>/selectedContract/downwardFlex}%"/>
                                    </VBox>
                                    <VBox id="_IDGenVBox10">
                                        <Label id="_IDGenLabel43" text="Make-Up Gas" design="Bold"/>
                                        <Text id="_IDGenText3" text="{ap>/selectedContract/makeUpGas} {ap>/selectedContract/uom}"/>
                                    </VBox>
                                    <VBox id="_IDGenVBox11">
                                        <Label id="_IDGenLabel44" text="Make-Good Gas" design="Bold"/>
                                        <Text id="_IDGenText4" text="{ap>/selectedContract/makeGoodGas} {ap>/selectedContract/uom}"/>
                                    </VBox>
                                    <VBox id="_IDGenVBox12">
                                        <Label id="_IDGenLabel45" text="FM Deficiency" design="Bold"/>
                                        <Text id="_IDGenText5" text="{ap>/selectedContract/fmDeficiency} {ap>/selectedContract/uom}"/>
                                    </VBox>
                                    <VBox id="_IDGenVBox13">
                                        <Label id="_IDGenLabel46" text="S/D Days Allowed" design="Bold"/>
                                        <Text id="_IDGenText35" text="{ap>/selectedContract/sdDaysAllowed} days"/>
                                    </VBox>
                                    <VBox id="_IDGenVBox14">
                                        <Label id="_IDGenLabel47" text="UOM" design="Bold"/>
                                        <Text id="_IDGenText36" text="{ap>/selectedContract/uom}"/>
                                    </VBox>
                                    <VBox id="_IDGenVBox15">
                                        <Label id="_IDGenLabel48" text="TOP %" design="Bold"/>
                                        <Text id="_IDGenText37" text="{ap>/selectedContract/topPercent}%"/>
                                    </VBox>
                                </l:content>
                            </l:Grid>

                            <!-- AACQ Calculation Formula strip -->
                            <MessageStrip id="_IDGenMessageStrip"
                                text="AACQ Formula: ACQ ({ap>/selectedContract/acq}) + Upward Flex ({ap>/selectedContract/upwardFlex}%) – Downward Flex ({ap>/selectedContract/downwardFlex}%) + Make-Up Gas ({ap>/selectedContract/makeUpGas}) + Make-Good Gas ({ap>/selectedContract/makeGoodGas}) = {ap>/selectedContract/aacq} {ap>/selectedContract/uom}"
                                type="Information"
                                showIcon="true"
                                class="sapUiSmallMargin"/>

                            <!-- Quarterly limits reference (from Screen 1) -->
                            <HBox id="_IDGenHBox4" class="sapUiSmallMarginBegin sapUiSmallMarginBottom" alignItems="Center">
                                <Label id="_IDGenLabel49" text="Corporate Quarterly Limits:" design="Bold" class="sapUiSmallMarginEnd"/>
                                <ObjectStatus id="_IDGenObjectStatus17" text="Q1 ≤ {ap>/quarterlyLimits/q1Limit}%" state="Information" class="sapUiSmallMarginEnd"/>
                                <ObjectStatus id="_IDGenObjectStatus18" text="Q2 ≤ {ap>/quarterlyLimits/q2Limit}%" state="Information" class="sapUiSmallMarginEnd"/>
                                <ObjectStatus id="_IDGenObjectStatus19" text="Q3 ≤ {ap>/quarterlyLimits/q3Limit}%" state="Information" class="sapUiSmallMarginEnd"/>
                                <ObjectStatus id="_IDGenObjectStatus20" text="Q4 ≤ {ap>/quarterlyLimits/q4Limit}%" state="Information"/>
                            </HBox>

                        </content>
                    </Panel>
         </VBox>

         <!-- monthly qty entered content -->

          <VBox class="filterArea sapUiSmallMarginTop">
                <VBox
                    id="emptyState"
                    visible="{= !${ap>/ui/contractSelected}}"
                    alignItems="Center"
                    class="sapUiLargeMarginTop">
                    <core:Icon id="_IDGenIcon2"
                        src="sap-icon://customer"
                        size="4rem"
                        color="#c2c2c2"
                        class="sapUiSmallMarginBottom"/>
                    <Title id="_IDGenTitle5" text="No Contract Selected" level="H4"/>
                    <Text id="_IDGenText38"
                        text="Select Calendar Year, Customer ID, and Contract Number above, then click 'Load Contract'."
                        textAlign="Center"
                        class="sapUiSmallMarginTop"/>
                </VBox>

                <!-- ══ SECTION 1: MONTHLY PLAN ENTRY ══ -->
                <VBox id="_IDGenVBox16" visible="{ap>/ui/contractSelected}">

                    <!-- Validation warning strip -->
                    <MessageStrip
                        id="qtrWarningStrip"
                        text="⚠ One or more quarterly totals exceed the allowed percentage. Please adjust monthly quantities. AACQ ({ap>/selectedContract/aacq} {ap>/selectedContract/uom}) must remain unchanged."
                        type="Warning"
                        showIcon="true"
                        showCloseButton="false"
                        visible="{= ${ap>/annualPlan/q1Warning} || ${ap>/annualPlan/q2Warning} ||
                                    ${ap>/annualPlan/q3Warning} || ${ap>/annualPlan/q4Warning}}"
                        class="sapUiSmallMarginBottom"/>

                    <!-- Annual total mismatch error -->
                    <MessageStrip
                        id="aacqMismatchStrip"
                        text="Annual total ({ap>/annualPlan/annualTotal} {ap>/selectedContract/uom}) does not match AACQ ({ap>/selectedContract/aacq} {ap>/selectedContract/uom}). Adjust monthly quantities so the total equals the AACQ."
                        type="Error"
                        showIcon="true"
                        visible="{= ${ap>/ui/contractSelected} &amp;&amp;
                                    ${ap>/annualPlan/annualTotal} !== 0 &amp;&amp;
                                    !${ap>/annualPlan/aacqMatch}}"
                        class="sapUiSmallMarginBottom"/>

                    <!-- Plan submitted confirmation -->
                    <MessageStrip
                        id="submittedStrip"
                        text="✓ Annual plan submitted successfully. It has been sent to your Zonal Office for review and approval."
                        type="Success"
                        showIcon="true"
                        visible="{ap>/ui/planSubmitted}"
                        class="sapUiSmallMarginBottom"/>

                    <!-- Section Title + AACQ progress -->
                    <HBox id="_IDGenHBox5" alignItems="Center" justifyContent="SpaceBetween"
                        class="sapUiSmallMarginBottom">
                        <Title id="_IDGenTitle6" text="Month-wise Quantity Entry" level="H4"/>
                        <HBox id="_IDGenHBox6" alignItems="Center">
                            <Label id="_IDGenLabel50" text="Annual Total:" design="Bold" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus
                                id="annualTotalStatus"
                                text="{ap>/annualPlan/annualTotal} / {ap>/selectedContract/aacq} {ap>/selectedContract/uom}"
                                state="{ap>/annualPlan/annualState}"
                                icon="{= ${ap>/annualPlan/aacqMatch} ? 'sap-icon://accept' : 'sap-icon://error'}"/>
                        </HBox>
                    </HBox>

                    <!-- ────────────────────────────────────────────────────
                         QUARTER 1: Jan / Feb / Mar
                    ──────────────────────────────────────────────────── -->
                    <Panel
                        id="q1Panel"
                        backgroundDesign="Solid"
                        class="sapUiSmallMarginBottom">
                        <headerToolbar>
                            <Toolbar id="_IDGenToolbar1">
                                <Title id="_IDGenTitle7" text="Quarter 1  (January – March)" level="H5"/>
                                <ToolbarSpacer id="_IDGenToolbarSpacer4"/>
                                <ObjectStatus
                                    id="q1Status"
                                    text="Q1 Total: {ap>/annualPlan/q1Total} {ap>/selectedContract/uom}  ({ap>/annualPlan/q1Pct}%  |  Limit: {ap>/quarterlyLimits/q1Limit}%)"
                                    state="{ap>/annualPlan/q1State}"
                                    icon="{= ${ap>/annualPlan/q1State} === 'Success' ? 'sap-icon://accept' :
                                              ${ap>/annualPlan/q1State} === 'Warning' ? 'sap-icon://warning' :
                                              ${ap>/annualPlan/q1State} === 'Error'   ? 'sap-icon://error'   : '' }"/>
                            </Toolbar>
                        </headerToolbar>
                        <content>
                            <HBox id="_IDGenHBox7" wrap="Wrap" class="sapUiSmallMargin">
                                <!-- January -->
                                <VBox id="_IDGenVBox17" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel51" text="January *" design="Bold"/>
                                    <StepInput
                                        id="siJan"
                                        value="{ap>/annualPlan/jan}"
                                        min="0" step="1"
                                        displayValuePrecision="0"
                                        description="{ap>/selectedContract/uom}"
                                        width="100%"
                                        enabled="{= !${ap>/ui/planSubmitted}}"
                                        change=".onMonthChange"/>
                                </VBox>
                                <!-- February -->
                                <VBox id="_IDGenVBox18" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel52" text="February *" design="Bold"/>
                                    <StepInput
                                        id="siFeb"
                                        value="{ap>/annualPlan/feb}"
                                        min="0" step="1"
                                        displayValuePrecision="0"
                                        description="{ap>/selectedContract/uom}"
                                        width="100%"
                                        enabled="{= !${ap>/ui/planSubmitted}}"
                                        change=".onMonthChange"/>
                                </VBox>
                                <!-- March -->
                                <VBox id="_IDGenVBox19" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel53" text="March *" design="Bold"/>
                                    <StepInput
                                        id="siMar"
                                        value="{ap>/annualPlan/mar}"
                                        min="0" step="1"
                                        displayValuePrecision="0"
                                        description="{ap>/selectedContract/uom}"
                                        width="100%"
                                        enabled="{= !${ap>/ui/planSubmitted}}"
                                        change=".onMonthChange"/>
                                </VBox>
                                <!-- Q1 Auto-calc total -->
                                <VBox id="_IDGenVBox20" width="160px" class="sapUiSmallMarginBegin">
                                    <Label id="_IDGenLabel54" text="Q1 Auto-Total" design="Bold"/>
                                    <ObjectStatus id="_IDGenObjectStatus21"
                                        text="{ap>/annualPlan/q1Total} {ap>/selectedContract/uom}"
                                        state="{ap>/annualPlan/q1State}"
                                        class="sapUiSmallMarginTop"/>
                                    <Text id="_IDGenText39"
                                        text="{ap>/annualPlan/q1Pct}% of AACQ"
                                       />
                                </VBox>
                            </HBox>
                        </content>
                    </Panel>

                    <!-- ────────────────────────────────────────────────────
                         QUARTER 2: Apr / May / Jun
                    ──────────────────────────────────────────────────── -->
                    <Panel
                        id="q2Panel"
                        backgroundDesign="Solid"
                        class="sapUiSmallMarginBottom">
                        <headerToolbar>
                            <Toolbar id="_IDGenToolbar3">
                                <Title id="_IDGenTitle8" text="Quarter 2  (April – June)" level="H5"/>
                                <ToolbarSpacer id="_IDGenToolbarSpacer6"/>
                                <ObjectStatus
                                    id="q2Status"
                                    text="Q2 Total: {ap>/annualPlan/q2Total} {ap>/selectedContract/uom}  ({ap>/annualPlan/q2Pct}%  |  Limit: {ap>/quarterlyLimits/q2Limit}%)"
                                    state="{ap>/annualPlan/q2State}"
                                    icon="{= ${ap>/annualPlan/q2State} === 'Success' ? 'sap-icon://accept' :
                                              ${ap>/annualPlan/q2State} === 'Warning' ? 'sap-icon://warning' :
                                              ${ap>/annualPlan/q2State} === 'Error'   ? 'sap-icon://error'   : '' }"/>
                            </Toolbar>
                        </headerToolbar>
                        <content>
                            <HBox id="_IDGenHBox8" wrap="Wrap" class="sapUiSmallMargin">
                                <VBox id="_IDGenVBox21" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel55" text="April *" design="Bold"/>
                                    <StepInput id="siApr" value="{ap>/annualPlan/apr}" min="0" step="1"
                                        displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                        width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                </VBox>
                                <VBox id="_IDGenVBox22" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel56" text="May *" design="Bold"/>
                                    <StepInput id="siMay" value="{ap>/annualPlan/may}" min="0" step="1"
                                        displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                        width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                </VBox>
                                <VBox id="_IDGenVBox23" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel57" text="June *" design="Bold"/>
                                    <StepInput id="siJun" value="{ap>/annualPlan/jun}" min="0" step="1"
                                        displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                        width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                </VBox>
                                <VBox id="_IDGenVBox24" width="160px" class="sapUiSmallMarginBegin">
                                    <Label id="_IDGenLabel58" text="Q2 Auto-Total" design="Bold"/>
                                    <ObjectStatus id="_IDGenObjectStatus22" text="{ap>/annualPlan/q2Total} {ap>/selectedContract/uom}"
                                        state="{ap>/annualPlan/q2State}" class="sapUiSmallMarginTop"/>
                                    <Text id="_IDGenText40" text="{ap>/annualPlan/q2Pct}% of AACQ"/>
                                </VBox>
                            </HBox>
                        </content>
                    </Panel>

                    <!-- ────────────────────────────────────────────────────
                         QUARTER 3: Jul / Aug / Sep
                    ──────────────────────────────────────────────────── -->
                    <Panel
                        id="q3Panel"
                        backgroundDesign="Solid"
                        class="sapUiSmallMarginBottom">
                        <headerToolbar>
                            <Toolbar id="_IDGenToolbar4">
                                <Title id="_IDGenTitle9" text="Quarter 3  (July – September)" level="H5"/>
                                <ToolbarSpacer id="_IDGenToolbarSpacer7"/>
                                <ObjectStatus
                                    id="q3Status"
                                    text="Q3 Total: {ap>/annualPlan/q3Total} {ap>/selectedContract/uom}  ({ap>/annualPlan/q3Pct}%  |  Limit: {ap>/quarterlyLimits/q3Limit}%)"
                                    state="{ap>/annualPlan/q3State}"
                                    icon="{= ${ap>/annualPlan/q3State} === 'Success' ? 'sap-icon://accept' :
                                              ${ap>/annualPlan/q3State} === 'Warning' ? 'sap-icon://warning' :
                                              ${ap>/annualPlan/q3State} === 'Error'   ? 'sap-icon://error'   : '' }"/>
                            </Toolbar>
                        </headerToolbar>
                        <content>
                            <HBox id="_IDGenHBox9" wrap="Wrap" class="sapUiSmallMargin">
                                <VBox id="_IDGenVBox25" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel59" text="July *" design="Bold"/>
                                    <StepInput id="siJul" value="{ap>/annualPlan/jul}" min="0" step="1"
                                        displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                        width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                </VBox>
                                <VBox id="_IDGenVBox26" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel60" text="August *" design="Bold"/>
                                    <StepInput id="siAug" value="{ap>/annualPlan/aug}" min="0" step="1"
                                        displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                        width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                </VBox>
                                <VBox id="_IDGenVBox27" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel61" text="September *" design="Bold"/>
                                    <StepInput id="siSep" value="{ap>/annualPlan/sep}" min="0" step="1"
                                        displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                        width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                </VBox>
                                <VBox id="_IDGenVBox28" width="160px" class="sapUiSmallMarginBegin">
                                    <Label id="_IDGenLabel62" text="Q3 Auto-Total" design="Bold"/>
                                    <ObjectStatus id="_IDGenObjectStatus23" text="{ap>/annualPlan/q3Total} {ap>/selectedContract/uom}"
                                        state="{ap>/annualPlan/q3State}" class="sapUiSmallMarginTop"/>
                                    <Text id="_IDGenText41" text="{ap>/annualPlan/q3Pct}% of AACQ" />
                                </VBox>
                            </HBox>
                        </content>
                    </Panel>

                    <!-- ────────────────────────────────────────────────────
                         QUARTER 4: Oct / Nov / Dec
                    ──────────────────────────────────────────────────── -->
                    <Panel
                        id="q4Panel"
                        backgroundDesign="Solid"
                        class="sapUiSmallMarginBottom">
                        <headerToolbar>
                            <Toolbar id="_IDGenToolbar5">
                                <Title id="_IDGenTitle10" text="Quarter 4  (October – December)" level="H5"/>
                                <ToolbarSpacer id="_IDGenToolbarSpacer8"/>
                                <ObjectStatus
                                    id="q4Status"
                                    text="Q4 Total: {ap>/annualPlan/q4Total} {ap>/selectedContract/uom}  ({ap>/annualPlan/q4Pct}%  |  Limit: {ap>/quarterlyLimits/q4Limit}%)"
                                    state="{ap>/annualPlan/q4State}"
                                    icon="{= ${ap>/annualPlan/q4State} === 'Success' ? 'sap-icon://accept' :
                                              ${ap>/annualPlan/q4State} === 'Warning' ? 'sap-icon://warning' :
                                              ${ap>/annualPlan/q4State} === 'Error'   ? 'sap-icon://error'   : '' }"/>
                            </Toolbar>
                        </headerToolbar>
                        <content>
                            <HBox id="_IDGenHBox10" wrap="Wrap" class="sapUiSmallMargin">
                                <VBox id="_IDGenVBox29" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel63" text="October *" design="Bold"/>
                                    <StepInput id="siOct" value="{ap>/annualPlan/oct}" min="0" step="1"
                                        displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                        width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                </VBox>
                                <VBox id="_IDGenVBox30" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel64" text="November *" design="Bold"/>
                                    <StepInput id="siNov" value="{ap>/annualPlan/nov}" min="0" step="1"
                                        displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                        width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                </VBox>
                                <VBox id="_IDGenVBox31" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel65" text="December *" design="Bold"/>
                                    <StepInput id="siDec" value="{ap>/annualPlan/dec}" min="0" step="1"
                                        displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                        width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                </VBox>
                                <VBox id="_IDGenVBox32" width="160px" class="sapUiSmallMarginBegin">
                                    <Label id="_IDGenLabel66" text="Q4 Auto-Total" design="Bold"/>
                                    <ObjectStatus id="_IDGenObjectStatus24" text="{ap>/annualPlan/q4Total} {ap>/selectedContract/uom}"
                                        state="{ap>/annualPlan/q4State}" class="sapUiSmallMarginTop"/>
                                    <Text id="_IDGenText42" text="{ap>/annualPlan/q4Pct}% of AACQ" />
                                </VBox>
                            </HBox>
                        </content>
                    </Panel>

                    <!-- Annual Summary Bar -->
                    <HBox id="_IDGenHBox11"
                        alignItems="Center"
                        justifyContent="SpaceBetween"
                        class="sapUiSmallMarginBottom sapUiSmallMarginTop"
                        >
                        <HBox id="_IDGenHBox12" alignItems="Center">
                            <Label id="_IDGenLabel67" text="Annual Summary:" design="Bold" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="_IDGenObjectStatus25" text="Q1: {ap>/annualPlan/q1Total}" state="{ap>/annualPlan/q1State}" class="sapUiSmallMarginEnd"/>
                            <Text id="_IDGenText43" text="+" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="_IDGenObjectStatus26" text="Q2: {ap>/annualPlan/q2Total}" state="{ap>/annualPlan/q2State}" class="sapUiSmallMarginEnd"/>
                            <Text id="_IDGenText44" text="+" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="_IDGenObjectStatus27" text="Q3: {ap>/annualPlan/q3Total}" state="{ap>/annualPlan/q3State}" class="sapUiSmallMarginEnd"/>
                            <Text id="_IDGenText45" text="+" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="_IDGenObjectStatus28" text="Q4: {ap>/annualPlan/q4Total}" state="{ap>/annualPlan/q4State}" class="sapUiSmallMarginEnd"/>
                            <Text id="_IDGenText46" text="=" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="_IDGenObjectStatus29"
                                text="Total: {ap>/annualPlan/annualTotal} {ap>/selectedContract/uom}"
                                state="{ap>/annualPlan/annualState}"
                                icon="{= ${ap>/annualPlan/aacqMatch} ? 'sap-icon://accept' : 'sap-icon://error'}"/>
                        </HBox>
                        <HBox id="_IDGenHBox13" alignItems="Center">
                            <Label id="_IDGenLabel68" text="AACQ Target:" design="Bold" class="sapUiSmallMarginEnd"/>
                            <ObjectNumber id="_IDGenObjectNumber3"
                                number="{ap>/selectedContract/aacq}"
                                unit="{ap>/selectedContract/uom}"
                                emphasized="true"/>
                        </HBox>
                    </HBox>

                    <!-- ════════════════════════════════════════════════
                         SECTION 2: SHUTDOWN / MAINTENANCE DAYS
                    ═════════════════════════════════════════════════ -->
                    <Panel
                        id="shutdownPanel"
                        headerText="Shutdown / Planned Maintenance Days"
                        expandable="true"
                        expanded="false"
                        class="sapUiSmallMarginBottom panelStyle"
                        visible="{ap>/ui/contractSelected}">

                        <headerToolbar>
                            <Toolbar id="_IDGenToolbar6">
                                <Title id="_IDGenTitle11" text="Shutdown / Planned Maintenance Days" level="H5"/>
                                <ToolbarSpacer id="_IDGenToolbarSpacer9"/>
                                <!-- <ObjectStatus
                                    text="S/D Allowed: {ap>/selectedContract/sdDaysAllowed} days  |  Remaining: {ap>/ui/sdDaysRemaining} days"
                                    state="{= ${ap>/ui/sdDaysRemaining} <= 3 ? 'Error' :
                                               ${ap>/ui/sdDaysRemaining} <= 7 ? 'Warning' : 'Information'}"/> -->
                                <Button id="_IDGenButton8"
                                    text="Add Shutdown Period"
                                    icon="sap-icon://add"
                                    type="Ghost"
                                    press=".onAddShutdownRow"
                                    enabled="{= !${ap>/ui/planSubmitted} &amp;&amp; ${ap>/ui/sdDaysRemaining} > 0}"
                                    class="sapUiSmallMarginBegin"/>
                            </Toolbar>
                        </headerToolbar>

                        <content>
                            <MessageStrip id="_IDGenMessageStrip1"
                                text="Shutdown days are subject to the total allowed days in the contract. The ACQ remains sacrosanct. This plan will be sent to Zonal for approval."
                                type="Information"
                                showIcon="true"
                                class="sapUiSmallMargin"/>

                            <!-- Shutdown Table -->
                            <table:Table
                                id="shutdownTable"
                                rows="{ap>/shutdownRows}"
                                selectionMode="None"
                                alternateRowColors="true"
                                visibleRowCount="{= Math.max(${ap>/shutdownRows}.length, 1)}"
                                rowHeight="48"
                                noData="No shutdown periods added. Click 'Add Shutdown Period' to begin."
                                class="sapUiSmallMargin zonalPlanTable">

                                <table:Column id="_IDGenColumn26" width="11rem" label="Month">
                                    <Label id="_IDGenLabel69" text="Month"/>
                                    <table:template>
                                        <Select id="_IDGenSelect"
                                            selectedKey="{ap>month}"
                                            width="100%"
                                            enabled="{= !${ap>/ui/planSubmitted}}"
                                            change=".onShutdownChange">
                                            <items>
                                                <core:Item id="_IDGenItem7" key="JAN" text="January"/>
                                                <core:Item id="_IDGenItem8" key="FEB" text="February"/>
                                                <core:Item id="_IDGenItem9" key="MAR" text="March"/>
                                                <core:Item id="_IDGenItem10" key="APR" text="April"/>
                                                <core:Item id="_IDGenItem11" key="MAY" text="May"/>
                                                <core:Item id="_IDGenItem12" key="JUN" text="June"/>
                                                <core:Item id="_IDGenItem13" key="JUL" text="July"/>
                                                <core:Item id="_IDGenItem14" key="AUG" text="August"/>
                                                <core:Item id="_IDGenItem15" key="SEP" text="September"/>
                                                <core:Item id="_IDGenItem16" key="OCT" text="October"/>
                                                <core:Item id="_IDGenItem17" key="NOV" text="November"/>
                                                <core:Item id="_IDGenItem18" key="DEC" text="December"/>
                                            </items>
                                        </Select>
                                    </table:template>
                                </table:Column>

                                <table:Column id="_IDGenColumn27" width="10rem" hAlign="Center" label="Shutdown Days">
                                    <Label id="_IDGenLabel70" text="Shutdown Days"/>
                                    <table:template>
                                        <StepInput id="_IDGenStepInput"
                                            value="{ap>days}"
                                            min="1"
                                            max="{ap>/ui/sdDaysRemaining}"
                                            step="1"
                                            displayValuePrecision="0"
                                            description="days"
                                            width="100%"
                                            enabled="{= !${ap>/ui/planSubmitted}}"
                                            change=".onShutdownChange"
                                            valueState="{ap>daysState}"
                                            valueStateText="Exceeds remaining S/D days allowance"/>
                                    </table:template>
                                </table:Column>

                                <table:Column id="_IDGenColumn28" width="12rem" hAlign="Center" label="Applicable DCQ">
                                    <Label id="_IDGenLabel71" text="Applicable DCQ"/>
                                    <table:template>
                                        <StepInput id="_IDGenStepInput1"
                                            value="{ap>dcq}"
                                            min="0"
                                            step="1"
                                            displayValuePrecision="0"
                                            description="{ap>/selectedContract/uom}"
                                            width="100%"
                                            enabled="{= !${ap>/ui/planSubmitted}}"
                                            change=".onShutdownChange"/>
                                    </table:template>
                                </table:Column>

                                <table:Column id="_IDGenColumn29" width="16rem" label="Reason / Notes">
                                    <Label id="_IDGenLabel72" text="Reason / Notes"/>
                                    <table:template>
                                        <Input id="_IDGenInput"
                                            value="{ap>reason}"
                                            placeholder="e.g. Annual maintenance shutdown"
                                            width="100%"
                                            enabled="{= !${ap>/ui/planSubmitted}}"/>
                                    </table:template>
                                </table:Column>

                                <table:Column id="_IDGenColumn30" width="8rem" hAlign="Center" label="Actions">
                                    <Label id="_IDGenLabel73" text="Actions"/>
                                    <table:template>
                                        <Button id="_IDGenButton9"
                                            icon="sap-icon://delete"
                                            type="Reject"
                                            tooltip="Remove this shutdown period"
                                            press=".onDeleteShutdownRow"
                                            enabled="{= !${ap>/ui/planSubmitted}}"/>
                                    </table:template>
                                </table:Column>

                            </table:Table>
                            

                        </content>
                        
                    </Panel>
        <HBox class="mainFooter" justifyContent="SpaceBetween" alignItems="Center">
          <HBox alignItems="Center">
          <ObjectStatus
                text="Annual Total: {ap>/annualPlan/annualTotal} / {ap>/selectedContract/aacq} {ap>/selectedContract/uom}"
                state="{ap>/annualPlan/annualState}"/>
            <ToolbarSpacer/>
          </HBox>
          <HBox>
            <Button text="Reset"
                    type="Ghost"
                    class="sapUiTinyMarginEnd"
                    icon="sap-icon://undo"
                    press=".onReset"
                    enabled="{ap>/ui/hasChanges}"
                    visible="{= !${ap>/ui/planSubmitted}}"/>
            <Button text="Save Draft"
                    type="Ghost"
                    icon="sap-icon://save"
                    class="sapUiTinyMarginEnd"
                    press=".onSaveDraft"
                    enabled="{ap>/ui/hasChanges}"
                    visible="{= !${ap>/ui/planSubmitted}}"/>
            <Button text="Submit Plan to Zonal"
                    type="Emphasized"
                    icon="sap-icon://paper-plane"
                    press=".onSubmitPlan"
                    enabled="{ap>/ui/submitEnabled}"
                    visible="{= !${ap>/ui/planSubmitted}}"/>
         </HBox>
        </HBox>

                </VBox>
                <!-- footer -->
       
          </VBox>

        
          
 </Page>
</mvc:View>
