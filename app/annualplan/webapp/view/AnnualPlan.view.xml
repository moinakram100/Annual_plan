<mvc:View
    controllerName="com.ingenx.annualplan.controller.AnnualPlan"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:form="sap.ui.layout.form"
    xmlns:table="sap.ui.table"
    xmlns:core="sap.ui.core"
    xmlns:tnt="sap.tnt"
    displayBlock="true">

    <Page showHeader="false">

        <!-- tool header -->
        <tnt:ToolHeader id="annualPlan__toolheader" class="sapUiTinyMargin header_nav">
            <Title id="annualPlan_Title" textAlign="Center" text="Annual Plan Submission" wrapping="false">
                <layoutData>
                    <OverflowToolbarLayoutData id="annualPlan_OverflowToolbarLayoutData" priority="Disappear"/>
                </layoutData>
            </Title>
            <ToolbarSpacer id="annualPlan_ToolbarSpacer"/>
        </tnt:ToolHeader>

        <!-- ══ ICON TAB BAR ══ -->
        <IconTabBar
            id="annualPlanTabBar"
            select=".onTabSelect"
            expandable="false"
            class="sapUiNoContentPadding iconTabbarArea">

            <items>

                <!-- ══ TAB 1: SUBMIT NEW PLAN ══ -->
                <IconTabFilter
                    id="tabSubmitNew"
                    key="submitNew"
                    text="Submit New Plan"
                    icon="sap-icon://add-document">
                    <content>

                        <!-- filter Bar -->
                        <HBox class="filterArea">
                            <HBox class="headerSelectArea">
                                <VBox class="sapUiTinyMarginBegin">
                                    <Label text="Material" design="Bold" width="90px"/>
                                    <Input
                                        id="inputMaterial"
                                        value="{ap>/contractSelection/material}"
                                        width="200px"
                                        showValueHelp="true"
                                        valueHelpOnly="true"
                                        valueHelpRequest=".onMaterialVH"
                                        placeholder="Select Material…"/>
                                </VBox>
                                <VBox class="sapUiTinyMarginBegin">
                                    <Label id="_IDGenabel39" text="Contract No." design="Bold" width="90px"/>
                                    <Input
                                        id="inputContractNo"
                                        width="200px"
                                        showValueHelp="true"
                                        valueHelpRequest=".onContractVH"
                                        change=".onContractChange"
                                        placeholder="Select Contract…"/>
                                </VBox>
                                <VBox>
                                    <Label text=""/>
                                    <HBox>
                                        <Button id="_IDGenButton6" text="Go" type="Emphasized"
                                            class="sapUiTinyMarginBegin" press=".onLoadContract"/>
                                        <Button id="_IDGenButton7" text="Clear" type="Ghost"
                                            press=".onClearAll" class="sapUiTinyMarginBegin"/>
                                    </HBox>
                                </VBox>
                            </HBox>
                        </HBox>

                        <!-- contract details -->
                        <VBox class="filterArea sapUiSmallMarginTop annualPlanArea" visible="{ap>/ui/contractSelected}">
                            <Panel id="contractInfoPanel" backgroundDesign="Solid" class="sapUiSmallMarginTop">
                                <content>
                                    <ObjectHeader
                                        id="contractHeader"
                                        title="{ap>/selectedContract/customerDesc}"
                                        number="{ap>/selectedContract/aacq}"
                                        numberUnit="{ap>/selectedContract/uom}"
                                        intro="{ap>/selectedContract/contractNumber} · {ap>/selectedContract/material}"
                                        backgroundDesign="Solid">
                                        <attributes>
                                            <ObjectAttribute title="Sales Office" text="{ap>/selectedContract/salesOffice}"/>
                                            <ObjectAttribute title="Valid Period"  text="{ap>/selectedContract/validFrom} – {ap>/selectedContract/validTo}"/>
                                            <ObjectAttribute title="TOP %"        text="{ap>/selectedContract/topPercent}%"/>
                                        </attributes>
                                        <statuses>
                                            <ObjectStatus title="Contract Status" text="{ap>/selectedContract/status}" state="Success" icon="sap-icon://accept"/>
                                        </statuses>
                                    </ObjectHeader>

                                    <l:Grid id="_IDGenGrid1" defaultSpan="XL2 L2 M4 S6"
                                        class="sapUiSmallMarginBegin sapUiSmallMarginBottom">
                                        <l:content>
                                            <VBox><Label text="ACQ" design="Bold"/>
                                                <ObjectNumber number="{ap>/selectedContract/acq}" unit="{ap>/selectedContract/uom}" emphasized="false"/></VBox>
                                            <VBox><Label text="AACQ (Calculated)" design="Bold"/>
                                                <ObjectNumber number="{ap>/selectedContract/aacq}" unit="{ap>/selectedContract/uom}" emphasized="true" state="Information"/></VBox>
                                            <VBox><Label text="Upward Flex %" design="Bold"/>
                                                <Text text="+{ap>/selectedContract/upwardFlex}%"/></VBox>
                                            <VBox><Label text="Downward Flex %" design="Bold"/>
                                                <Text text="-{ap>/selectedContract/downwardFlex}%"/></VBox>
                                            <VBox><Label text="Make-Up Gas" design="Bold"/>
                                                <Text text="{ap>/selectedContract/makeUpGas} {ap>/selectedContract/uom}"/></VBox>
                                            <VBox><Label text="Make-Good Gas" design="Bold"/>
                                                <Text text="{ap>/selectedContract/makeGoodGas} {ap>/selectedContract/uom}"/></VBox>
                                            <VBox><Label text="S/D Days Allowed" design="Bold"/>
                                                <Text text="{ap>/selectedContract/sdDaysAllowed} days"/></VBox>
                                            <VBox><Label text="UOM" design="Bold"/>
                                                <Text text="{ap>/selectedContract/uom}"/></VBox>
                                            <VBox><Label text="{ap>/selectedContract/topLabel}" design="Bold"/>
                                                <Text text="{ap>/selectedContract/topPercent}%" visible="{= ${ap>/selectedContract/topPercent} !== 0}"/></VBox>
                                        </l:content>
                                    </l:Grid>

                                    <MessageStrip
                                        text="AACQ Formula: ACQ ({ap>/selectedContract/acq}) + Upward Flex ({ap>/selectedContract/upwardFlex}%) – Downward Flex ({ap>/selectedContract/downwardFlex}%) + Make-Up Gas ({ap>/selectedContract/makeUpGas}) + Make-Good Gas ({ap>/selectedContract/makeGoodGas}) = {ap>/selectedContract/aacq} {ap>/selectedContract/uom}"
                                        type="Information" showIcon="true" class="sapUiSmallMargin"/>

                                    <HBox class="sapUiSmallMarginBegin sapUiSmallMarginBottom" alignItems="Center">
                                        <Label text="Corporate Quarterly Limits:" design="Bold" class="sapUiSmallMarginEnd"/>
                                        <ObjectStatus text="Q1 ≤ {ap>/quarterlyLimits/q1Limit}%" state="Information" class="sapUiSmallMarginEnd"/>
                                        <ObjectStatus text="Q2 ≤ {ap>/quarterlyLimits/q2Limit}%" state="Information" class="sapUiSmallMarginEnd"/>
                                        <ObjectStatus text="Q3 ≤ {ap>/quarterlyLimits/q3Limit}%" state="Information" class="sapUiSmallMarginEnd"/>
                                        <ObjectStatus text="Q4 ≤ {ap>/quarterlyLimits/q4Limit}%" state="Information"/>
                                    </HBox>
                                </content>
                            </Panel>
                        </VBox>

                        <!-- monthly qty content -->
                        <VBox class="filterArea sapUiSmallMarginTop">

                            <!-- Empty state -->
                            <VBox id="emptyState" visible="{= !${ap>/ui/contractSelected}}"
                                alignItems="Center" class="sapUiLargeMarginTop">
                                <core:Icon src="sap-icon://customer" size="4rem" color="#c2c2c2" class="sapUiSmallMarginBottom"/>
                                <Title text="No Contract Selected" level="H4"/>
                                <Text text="Select Material and Contract Number above, then click 'Go'"
                                    textAlign="Center" class="sapUiSmallMarginTop"/>
                            </VBox>

                            <VBox id="_IDGenVBox16" visible="{ap>/ui/contractSelected}">

                                <!-- Validation strips -->
                                <MessageStrip id="qtrWarningStrip"
                                    text="⚠ One or more quarterly totals exceed the allowed percentage. Please adjust monthly quantities."
                                    type="Warning" showIcon="true" showCloseButton="false"
                                    visible="{= ${ap>/annualPlan/q1Warning} || ${ap>/annualPlan/q2Warning} ||
                                                ${ap>/annualPlan/q3Warning} || ${ap>/annualPlan/q4Warning}}"
                                    class="sapUiSmallMarginBottom"/>

                                <MessageStrip id="aacqMismatchStrip"
                                    text="Annual total ({ap>/annualPlan/annualTotal} {ap>/selectedContract/uom}) does not match AACQ ({ap>/selectedContract/aacq} {ap>/selectedContract/uom})."
                                    type="Error" showIcon="true"
                                    visible="{= ${ap>/ui/contractSelected} &amp;&amp;
                                                ${ap>/annualPlan/annualTotal} !== 0 &amp;&amp;
                                                !${ap>/annualPlan/aacqMatch}}"
                                    class="sapUiSmallMarginBottom"/>

                                <MessageStrip id="submittedStrip"
                                    text="✓ Annual plan submitted successfully. Sent to Zonal Office for review."
                                    type="Success" showIcon="true"
                                    visible="{ap>/ui/planSubmitted}"
                                    class="sapUiSmallMarginBottom"/>

                                <!-- Annual total header -->
                                <HBox alignItems="Center" justifyContent="SpaceBetween" class="sapUiSmallMarginBottom">
                                    <Title text="Month-wise Quantity Entry" level="H4"/>
                                    <HBox alignItems="Center">
                                        <Label text="Annual Total:" design="Bold" class="sapUiSmallMarginEnd"/>
                                        <ObjectStatus
                                            text="{ap>/annualPlan/annualTotal} / {ap>/selectedContract/aacq} {ap>/selectedContract/uom}"
                                            state="{ap>/annualPlan/annualState}"
                                            icon="{= ${ap>/annualPlan/aacqMatch} ? 'sap-icon://accept' : 'sap-icon://error'}"/>
                                    </HBox>
                                </HBox>

                                <!-- Q1 -->
                                <Panel id="q1Panel" backgroundDesign="Solid" class="sapUiSmallMarginBottom">
                                    <headerToolbar>
                                        <Toolbar>
                                            <Title text="Quarter 1  (January – March)" level="H5"/>
                                            <ToolbarSpacer/>
                                            <ObjectStatus
                                                text="Q1 Total: {ap>/annualPlan/q1Total} {ap>/selectedContract/uom}  ({ap>/annualPlan/q1Pct}%  |  Limit: {ap>/quarterlyLimits/q1Limit}%)"
                                                state="{ap>/annualPlan/q1State}"
                                                icon="{= ${ap>/annualPlan/q1State} === 'Success' ? 'sap-icon://accept' :
                                                          ${ap>/annualPlan/q1State} === 'Warning' ? 'sap-icon://warning' :
                                                          ${ap>/annualPlan/q1State} === 'Error'   ? 'sap-icon://error' : '' }"/>
                                        </Toolbar>
                                    </headerToolbar>
                                    <content>
                                        <HBox wrap="Wrap" class="sapUiSmallMargin">
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="January *" design="Bold"/>
                                                <StepInput id="siJan" value="{ap>/annualPlan/jan}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="February *" design="Bold"/>
                                                <StepInput id="siFeb" value="{ap>/annualPlan/feb}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="March *" design="Bold"/>
                                                <StepInput id="siMar" value="{ap>/annualPlan/mar}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox width="160px" class="sapUiSmallMarginBegin">
                                                <Label text="Q1 Auto-Total" design="Bold"/>
                                                <ObjectStatus text="{ap>/annualPlan/q1Total} {ap>/selectedContract/uom}"
                                                    state="{ap>/annualPlan/q1State}" class="sapUiSmallMarginTop"/>
                                                <Text text="{ap>/annualPlan/q1Pct}% of ACQ"/>
                                            </VBox>
                                        </HBox>
                                    </content>
                                </Panel>

                                <!-- Q2 -->
                                <Panel id="q2Panel" backgroundDesign="Solid" class="sapUiSmallMarginBottom">
                                    <headerToolbar>
                                        <Toolbar>
                                            <Title text="Quarter 2  (April – June)" level="H5"/>
                                            <ToolbarSpacer/>
                                            <ObjectStatus
                                                text="Q2 Total: {ap>/annualPlan/q2Total} {ap>/selectedContract/uom}  ({ap>/annualPlan/q2Pct}%  |  Limit: {ap>/quarterlyLimits/q2Limit}%)"
                                                state="{ap>/annualPlan/q2State}"
                                                icon="{= ${ap>/annualPlan/q2State} === 'Success' ? 'sap-icon://accept' :
                                                          ${ap>/annualPlan/q2State} === 'Warning' ? 'sap-icon://warning' :
                                                          ${ap>/annualPlan/q2State} === 'Error'   ? 'sap-icon://error' : '' }"/>
                                        </Toolbar>
                                    </headerToolbar>
                                    <content>
                                        <HBox wrap="Wrap" class="sapUiSmallMargin">
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="April *" design="Bold"/>
                                                <StepInput id="siApr" value="{ap>/annualPlan/apr}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="May *" design="Bold"/>
                                                <StepInput id="siMay" value="{ap>/annualPlan/may}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="June *" design="Bold"/>
                                                <StepInput id="siJun" value="{ap>/annualPlan/jun}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox width="160px" class="sapUiSmallMarginBegin">
                                                <Label text="Q2 Auto-Total" design="Bold"/>
                                                <ObjectStatus text="{ap>/annualPlan/q2Total} {ap>/selectedContract/uom}"
                                                    state="{ap>/annualPlan/q2State}" class="sapUiSmallMarginTop"/>
                                                <Text text="{ap>/annualPlan/q2Pct}% of ACQ"/>
                                            </VBox>
                                        </HBox>
                                    </content>
                                </Panel>

                                <!-- Q3 -->
                                <Panel id="q3Panel" backgroundDesign="Solid" class="sapUiSmallMarginBottom">
                                    <headerToolbar>
                                        <Toolbar>
                                            <Title text="Quarter 3  (July – September)" level="H5"/>
                                            <ToolbarSpacer/>
                                            <ObjectStatus
                                                text="Q3 Total: {ap>/annualPlan/q3Total} {ap>/selectedContract/uom}  ({ap>/annualPlan/q3Pct}%  |  Limit: {ap>/quarterlyLimits/q3Limit}%)"
                                                state="{ap>/annualPlan/q3State}"
                                                icon="{= ${ap>/annualPlan/q3State} === 'Success' ? 'sap-icon://accept' :
                                                          ${ap>/annualPlan/q3State} === 'Warning' ? 'sap-icon://warning' :
                                                          ${ap>/annualPlan/q3State} === 'Error'   ? 'sap-icon://error' : '' }"/>
                                        </Toolbar>
                                    </headerToolbar>
                                    <content>
                                        <HBox wrap="Wrap" class="sapUiSmallMargin">
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="July *" design="Bold"/>
                                                <StepInput id="siJul" value="{ap>/annualPlan/jul}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="August *" design="Bold"/>
                                                <StepInput id="siAug" value="{ap>/annualPlan/aug}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="September *" design="Bold"/>
                                                <StepInput id="siSep" value="{ap>/annualPlan/sep}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox width="160px" class="sapUiSmallMarginBegin">
                                                <Label text="Q3 Auto-Total" design="Bold"/>
                                                <ObjectStatus text="{ap>/annualPlan/q3Total} {ap>/selectedContract/uom}"
                                                    state="{ap>/annualPlan/q3State}" class="sapUiSmallMarginTop"/>
                                                <Text text="{ap>/annualPlan/q3Pct}% of ACQ"/>
                                            </VBox>
                                        </HBox>
                                    </content>
                                </Panel>

                                <!-- Q4 -->
                                <Panel id="q4Panel" backgroundDesign="Solid" class="sapUiSmallMarginBottom">
                                    <headerToolbar>
                                        <Toolbar>
                                            <Title text="Quarter 4  (October – December)" level="H5"/>
                                            <ToolbarSpacer/>
                                            <ObjectStatus
                                                text="Q4 Total: {ap>/annualPlan/q4Total} {ap>/selectedContract/uom}  ({ap>/annualPlan/q4Pct}%  |  Limit: {ap>/quarterlyLimits/q4Limit}%)"
                                                state="{ap>/annualPlan/q4State}"
                                                icon="{= ${ap>/annualPlan/q4State} === 'Success' ? 'sap-icon://accept' :
                                                          ${ap>/annualPlan/q4State} === 'Warning' ? 'sap-icon://warning' :
                                                          ${ap>/annualPlan/q4State} === 'Error'   ? 'sap-icon://error' : '' }"/>
                                        </Toolbar>
                                    </headerToolbar>
                                    <content>
                                        <HBox wrap="Wrap" class="sapUiSmallMargin">
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="October *" design="Bold"/>
                                                <StepInput id="siOct" value="{ap>/annualPlan/oct}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="November *" design="Bold"/>
                                                <StepInput id="siNov" value="{ap>/annualPlan/nov}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox class="sapUiSmallMarginEnd" width="250px">
                                                <Label text="December *" design="Bold"/>
                                                <StepInput id="siDec" value="{ap>/annualPlan/dec}" min="0" step="1"
                                                    displayValuePrecision="0" description="{ap>/selectedContract/uom}"
                                                    width="100%" enabled="{= !${ap>/ui/planSubmitted}}" change=".onMonthChange"/>
                                            </VBox>
                                            <VBox width="160px" class="sapUiSmallMarginBegin">
                                                <Label text="Q4 Auto-Total" design="Bold"/>
                                                <ObjectStatus text="{ap>/annualPlan/q4Total} {ap>/selectedContract/uom}"
                                                    state="{ap>/annualPlan/q4State}" class="sapUiSmallMarginTop"/>
                                                <Text text="{ap>/annualPlan/q4Pct}% of ACQ"/>
                                            </VBox>
                                        </HBox>
                                    </content>
                                </Panel>

                                <!-- Annual Summary Bar -->
                                <HBox alignItems="Center" justifyContent="SpaceBetween"
                                    class="sapUiSmallMarginBottom sapUiSmallMarginTop">
                                    <HBox alignItems="Center">
                                        <Label text="Annual Summary:" design="Bold" class="sapUiSmallMarginEnd"/>
                                        <ObjectStatus text="Q1: {ap>/annualPlan/q1Total}" state="{ap>/annualPlan/q1State}" class="sapUiSmallMarginEnd"/>
                                        <Text text="+" class="sapUiSmallMarginEnd"/>
                                        <ObjectStatus text="Q2: {ap>/annualPlan/q2Total}" state="{ap>/annualPlan/q2State}" class="sapUiSmallMarginEnd"/>
                                        <Text text="+" class="sapUiSmallMarginEnd"/>
                                        <ObjectStatus text="Q3: {ap>/annualPlan/q3Total}" state="{ap>/annualPlan/q3State}" class="sapUiSmallMarginEnd"/>
                                        <Text text="+" class="sapUiSmallMarginEnd"/>
                                        <ObjectStatus text="Q4: {ap>/annualPlan/q4Total}" state="{ap>/annualPlan/q4State}" class="sapUiSmallMarginEnd"/>
                                        <Text text="=" class="sapUiSmallMarginEnd"/>
                                        <ObjectStatus
                                            text="Total: {ap>/annualPlan/annualTotal} {ap>/selectedContract/uom}"
                                            state="{ap>/annualPlan/annualState}"
                                            icon="{= ${ap>/annualPlan/aacqMatch} ? 'sap-icon://accept' : 'sap-icon://error'}"/>
                                    </HBox>
                                    <HBox alignItems="Center">
                                        <Label text="AACQ Target:" design="Bold" class="sapUiSmallMarginEnd"/>
                                        <ObjectNumber number="{ap>/selectedContract/aacq}"
                                            unit="{ap>/selectedContract/uom}" emphasized="true"/>
                                    </HBox>
                                </HBox>

                                <!-- Shutdown Panel -->
                                <Panel id="shutdownPanel" expandable="true" expanded="false"
                                    class="sapUiSmallMarginBottom panelStyle"
                                    visible="{ap>/ui/contractSelected}">
                                    <headerToolbar>
                                        <Toolbar>
                                            <Title text="Shutdown / Planned Maintenance Days" level="H5"/>
                                            <ToolbarSpacer/>
                                            <Button text="Add Shutdown Period" icon="sap-icon://add"
                                                type="Ghost" press=".onAddShutdownRow"
                                                enabled="{= !${ap>/ui/planSubmitted} &amp;&amp; ${ap>/ui/sdDaysRemaining} > 0}"
                                                class="sapUiSmallMarginBegin"/>
                                        </Toolbar>
                                    </headerToolbar>
                                    <content>
                                        <MessageStrip
                                            text="Shutdown days are subject to the total allowed days in the contract."
                                            type="Information" showIcon="true" class="sapUiSmallMargin"/>
                                        <table:Table id="shutdownTable" rows="{ap>/shutdownRows}"
                                            selectionMode="None" alternateRowColors="true"
                                            visibleRowCount="3" rowHeight="48"
                                            noData="No shutdown periods added."
                                            class="sapUiSmallMargin sapUiLargeMarginBottom zonalPlanTable">
                                            <table:Column label="Date">
                                                <Label text="Date"/>
                                                <table:template>
                                                    <DateRangeSelection id="DRS2" change=".onShutdownChange"
                                                        dateValue="{ap>startDate}" secondDateValue="{ap>endDate}"/>
                                                </table:template>
                                            </table:Column>
                                            <table:Column hAlign="Center" label="Shutdown Days">
                                                <Label text="Shutdown Days"/>
                                                <table:template>
                                                    <StepInput value="{ap>days}" min="0" step="1"
                                                        displayValuePrecision="0" description="days"
                                                        width="100%" enabled="false"
                                                        valueState="{ap>daysState}"/>
                                                </table:template>
                                            </table:Column>
                                            <table:Column hAlign="Center" label="Applicable DCQ">
                                                <Label text="Applicable DCQ"/>
                                                <table:template>
                                                    <StepInput value="{ap>dcq}" min="0" step="1"
                                                        displayValuePrecision="0"
                                                        description="{ap>/selectedContract/uom}"
                                                        width="100%"
                                                        enabled="{= !${ap>/ui/planSubmitted}}"
                                                        change=".onShutdownChange"/>
                                                </table:template>
                                            </table:Column>
                                            <table:Column label="Reason / Notes">
                                                <Label text="Reason / Notes"/>
                                                <table:template>
                                                    <Input value="{ap>reason}"
                                                        placeholder="e.g. Annual maintenance shutdown"
                                                        width="100%"
                                                        enabled="{= !${ap>/ui/planSubmitted}}"/>
                                                </table:template>
                                            </table:Column>
                                            <table:Column hAlign="Center" label="Actions">
                                                <Label text="Actions"/>
                                                <table:template>
                                                    <Button icon="sap-icon://delete" type="Reject"
                                                        press=".onDeleteShutdownRow"
                                                        enabled="{= !${ap>/ui/planSubmitted}}"/>
                                                </table:template>
                                            </table:Column>
                                        </table:Table>
                                    </content>
                                </Panel>

                                <!-- Footer -->
                                <HBox class="mainFooter" justifyContent="SpaceBetween" alignItems="Center">
                                    <HBox alignItems="Center">
                                        <ObjectStatus
                                            text="Annual Total: {ap>/annualPlan/annualTotal} / {ap>/selectedContract/aacq} {ap>/selectedContract/uom}"
                                            state="{ap>/annualPlan/annualState}"/>
                                    </HBox>
                                    <HBox>
                                        <Button text="Reset" type="Ghost" class="sapUiTinyMarginEnd"
                                            icon="sap-icon://undo" press=".onReset"
                                            enabled="{ap>/ui/hasChanges}"
                                            visible="{= !${ap>/ui/planSubmitted}}"/>
                                        <Button text="Submit Plan to Zonal" type="Emphasized"
                                            icon="sap-icon://paper-plane" press=".onSubmitPlan"
                                            enabled="{ap>/ui/submitEnabled}"
                                            visible="{= !${ap>/ui/planSubmitted}}"/>
                                    </HBox>
                                </HBox>

                            </VBox>
                        </VBox>

                    </content>
                </IconTabFilter>

                <!-- ══ TAB 2: MY PLANS ══ -->
                <IconTabFilter
                    id="tabMyPlans"
                    key="myPlans"
                    text="My Plans"
                    icon="sap-icon://list"
                    >
                    <content>
                        <VBox class="filterArea sapUiSmallMarginTop">

                            <!-- Toolbar -->
                            <Toolbar>
                                <Title text="My Submitted Plans" level="H4"/>
                                <ObjectStatus text="{ap>/myPlans/count} plan(s)"
                                    state="Information" class="sapUiSmallMarginBegin"
                                    visible="{= ${ap>/myPlans/count} > 0}"/>
                                <ToolbarSpacer/>
                                <Button text="Refresh" icon="sap-icon://refresh"
                                    type="Ghost" press=".onRefreshMyPlans"/>
                            </Toolbar>

                            <!-- Loading -->
                            <VBox visible="{ap>/myPlans/loading}"
                                alignItems="Center" class="sapUiMediumMarginTop">
                                <BusyIndicator size="2rem"/>
                                <Text text="Loading your plans…" class="sapUiSmallMarginTop"/>
                            </VBox>

                            <!-- Empty state -->
                            <VBox visible="{= !${ap>/myPlans/loading} &amp;&amp; ${ap>/myPlans/count} === 0}"
                                alignItems="Center" class="sapUiLargeMarginTop">
                                <core:Icon src="sap-icon://document" size="4rem" color="#c2c2c2"
                                    class="sapUiSmallMarginBottom"/>
                                <Title text="No Plans Submitted Yet" level="H4"/>
                                <Text text="Go to 'Submit New Plan' tab to submit your first plan."
                                    textAlign="Center" class="sapUiSmallMarginTop"/>
                            </VBox>

                            <!-- Plans Table -->
                            <table:Table
                                id="myPlansTable"
                                rows="{ap>/myPlans/rows}"
                                selectionMode="None"
                                alternateRowColors="true"
                                visibleRowCount="8"
                                rowHeight="52"
                                visible="{= !${ap>/myPlans/loading} &amp;&amp; ${ap>/myPlans/count} > 0}"
                                enableBusyIndicator="true"
                                class="sapUiSmallMarginTop zonalPlanTable">

                                <table:Column width="14rem" label="Contract">
                                    <Label text="Contract"/>
                                    <table:template>
                                        <VBox>
                                            <Text text="{ap>contract}" wrapping="false"/>
                                            <ObjectStatus text="{ap>material}" state="Information"/>
                                        </VBox>
                                    </table:template>
                                </table:Column>

                                <table:Column width="10rem" label="Submitted On">
                                    <Label text="Submitted On"/>
                                    <table:template>
                                        <Text text="{ap>submittedOn}" wrapping="false"/>
                                    </table:template>
                                </table:Column>

                                <table:Column width="11rem" label="Status">
                                    <Label text="Approval Status"/>
                                    <table:template>
                                        <ObjectStatus
                                            text="{ap>approvalStatus}"
                                            state="{ap>approvalState}"
                                            icon="{= ${ap>approvalState} === 'Success' ? 'sap-icon://accept' :
                                                      ${ap>approvalState} === 'Error'   ? 'sap-icon://decline' :
                                                                                           'sap-icon://pending'}"/>
                                    </table:template>
                                </table:Column>

                                <table:Column width="8rem" hAlign="End" label="AACQ">
                                    <Label text="AACQ"/>
                                    <table:template>
                                        <ObjectNumber number="{ap>aacq}" unit="{ap>uom}"/>
                                    </table:template>
                                </table:Column>

                                <table:Column width="9rem" hAlign="Center" label="Q1 (Jan-Mar)">
                                    <Label text="Q1 (Jan-Mar)"/>
                                    <table:template>
                                        <ObjectStatus text="{ap>q1} ({ap>q1Pct}%)" state="{ap>q1State}"/>
                                    </table:template>
                                </table:Column>

                                <table:Column width="9rem" hAlign="Center" label="Q2 (Apr-Jun)">
                                    <Label text="Q2 (Apr-Jun)"/>
                                    <table:template>
                                        <ObjectStatus text="{ap>q2} ({ap>q2Pct}%)" state="{ap>q2State}"/>
                                    </table:template>
                                </table:Column>

                                <table:Column width="9rem" hAlign="Center" label="Q3 (Jul-Sep)">
                                    <Label text="Q3 (Jul-Sep)"/>
                                    <table:template>
                                        <ObjectStatus text="{ap>q3} ({ap>q3Pct}%)" state="{ap>q3State}"/>
                                    </table:template>
                                </table:Column>

                                <table:Column width="9rem" hAlign="Center" label="Q4 (Oct-Dec)">
                                    <Label text="Q4 (Oct-Dec)"/>
                                    <table:template>
                                        <ObjectStatus text="{ap>q4} ({ap>q4Pct}%)" state="{ap>q4State}"/>
                                    </table:template>
                                </table:Column>

                                <table:Column width="8rem" hAlign="Center" label="Actions">
                                    <Label text="Actions"/>
                                    <table:template>
                                        <Button text="View" type="Ghost"
                                            icon="sap-icon://detail-view"
                                            press=".onViewMyPlan"/>
                                    </table:template>
                                </table:Column>

                            </table:Table>

                        </VBox>
                    </content>
                </IconTabFilter>

            </items>
        </IconTabBar>

    </Page>
</mvc:View>