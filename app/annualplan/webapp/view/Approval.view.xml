<mvc:View
    controllerName="com.ingenx.annualplan.controller.Approval"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:l="sap.ui.layout"
    xmlns:table="sap.ui.table"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <f:DynamicPage id="approvalPage" showFooter="false">

        <!-- ── TITLE ── -->
        <f:title>
            <f:DynamicPageTitle id="_IDGenDynamicPageTitle2">
                <f:heading>
                    <Title id="_IDGenTitle12" text="Approval Workflow" level="H2"/>
                </f:heading>
                <!-- <f:subheading>
                    <Text text="Review and approve or reject Annual Plan and Reduction requests · {apv>/ui/fiscalYear}"/>
                </f:subheading> -->
                <f:snappedHeading>
                    <HBox id="_IDGenHBox20" alignItems="Center">
                        <Title id="_IDGenTitle18" text="Approval Workflow" level="H3" class="sapUiSmallMarginEnd"/>
                        <ObjectStatus id="_IDGenObjectStatus52" text="{apv>/ui/pendingCount} pending" state="Warning"/>
                    </HBox>
                </f:snappedHeading>
                <f:actions>
                    <Button id="_IDGenButton17" text="Refresh"       icon="sap-icon://refresh"   type="Ghost"     press=".onRefresh"/>
                    <Button id="_IDGenButton18" text="Export"        icon="sap-icon://download"  type="Ghost"     press=".onExport"/>
                    <Button id="_IDGenButton24" text="Load All"      icon="sap-icon://search"    type="Emphasized" press=".onLoadAll"/>
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

        <!-- ── HEADER: Summary KPI Tiles + Filter Bar ── -->
        <f:header>
            <f:DynamicPageHeader id="_IDGenDynamicPageHeader1" pinnable="true" backgroundDesign="Solid">
                <l:VerticalLayout id="_IDGenVerticalLayout10" width="100%">

                    <!-- KPI summary tiles (always visible) -->
                    <HBox id="_IDGenHBox21" wrap="Wrap" class="sapUiSmallMarginBottom" visible="{apv>/ui/dataLoaded}">
                        <GenericTile id="_IDGenGenericTile" header="Pending Approval" subheader="Awaiting decision" class="sapUiTinyMargin">
                            <tileContent>
                                <TileContent id="_IDGenTileContent">
                                    <content>
                                        <NumericContent id="_IDGenNumericContent"
                                            value="{apv>/ui/pendingCount}"
                                            valueColor="{= ${apv>/ui/pendingCount} > 0 ? 'Critical' : 'Good'}"
                                            icon="sap-icon://pending"/>
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>
                        <GenericTile id="_IDGenGenericTile1" header="Approved" subheader="This period" class="sapUiTinyMargin">
                            <tileContent>
                                <TileContent id="_IDGenTileContent1">
                                    <content>
                                        <NumericContent id="_IDGenNumericContent1" value="{apv>/ui/approvedCount}" valueColor="Good" icon="sap-icon://accept"/>
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>
                        <GenericTile id="_IDGenGenericTile2" header="Rejected" subheader="This period" class="sapUiTinyMargin">
                            <tileContent>
                                <TileContent id="_IDGenTileContent2">
                                    <content>
                                        <NumericContent id="_IDGenNumericContent2"
                                            value="{apv>/ui/rejectedCount}"
                                            valueColor="{= ${apv>/ui/rejectedCount} > 0 ? 'Error' : 'Good'}"
                                            icon="sap-icon://decline"/>
                                    </content>
                                </TileContent>
                            </tileContent>
                        </GenericTile>
                    </HBox>

                    <!-- Filter Bar -->
                    <Toolbar id="_IDGenToolbar7" design="Solid">
                        <Label id="_IDGenLabel100" text="Request Type" design="Bold" width="95px"/>
                        <Select id="selType" width="160px" selectedKey="{apv>/filters/requestType}">
                            <items>
                                <core:Item id="_IDGenItem69" key=""            text="All Types"/>
                                <core:Item id="_IDGenItem70" key="ANNUAL_PLAN" text="Annual Plan"/>
                                <core:Item id="_IDGenItem71" key="REDUCTION"   text="Reduction"/>
                            </items>
                        </Select>
                        <ToolbarSpacer id="_IDGenToolbarSpacer11" width="12px"/>
                        <Label id="_IDGenLabel101" text="Status" design="Bold" width="52px"/>
                        <Select id="selStatus" width="160px" selectedKey="{apv>/filters/status}">
                            <items>
                                <core:Item id="_IDGenItem72" key=""         text="All Statuses"/>
                                <core:Item id="_IDGenItem73" key="PENDING"  text="Pending Approval"/>
                                <core:Item id="_IDGenItem74" key="APPROVED" text="Approved"/>
                                <core:Item id="_IDGenItem75" key="REJECTED" text="Rejected"/>
                            </items>
                        </Select>
                        <ToolbarSpacer id="_IDGenToolbarSpacer12" width="12px"/>
                        <Label id="_IDGenLabel102" text="Material" design="Bold" width="65px"/>
                        <Select id="selMaterial" width="130px" selectedKey="{apv>/filters/material}">
                            <items>
                                <core:Item id="_IDGenItem76" key=""     text="All"/>
                                <core:Item id="_IDGenItem77" key="RLNG" text="RLNG"/>
                                <core:Item id="_IDGenItem78" key="PNG"  text="PNG"/>
                                <core:Item id="_IDGenItem79" key="CNG"  text="CNG"/>
                            </items>
                        </Select>
                        <ToolbarSpacer id="_IDGenToolbarSpacer13" width="12px"/>
                        <Label id="_IDGenLabel103" text="Customer" design="Bold" width="70px"/>
                        <Select id="selCustomer" width="165px" selectedKey="{apv>/filters/customer}">
                            <items>
                                <core:Item id="_IDGenItem80" key=""           text="All Customers"/>
                                <core:Item id="_IDGenItem81" key="CUST-1001"  text="ABC Power Ltd"/>
                                <core:Item id="_IDGenItem82" key="CUST-1002"  text="XYZ Fertilizer Co."/>
                                <core:Item id="_IDGenItem83" key="CUST-1004"  text="LMN Energy Ltd"/>
                                <core:Item id="_IDGenItem84" key="CUST-1005"  text="DEF Textiles Pvt"/>
                            </items>
                        </Select>
                        <ToolbarSpacer id="_IDGenToolbarSpacer14" width="12px"/>
                        <Button id="_IDGenButton25" text="Go"    type="Emphasized" icon="sap-icon://search" press=".onApplyFilter"/>
                        <Button id="_IDGenButton26" text="Clear" type="Ghost"                               press=".onClearFilter" class="sapUiTinyMarginBegin"/>
                    </Toolbar>

                </l:VerticalLayout>
            </f:DynamicPageHeader>
        </f:header>

        <!-- ═══════════════════════════════════════════════════════════
             CONTENT
        ════════════════════════════════════════════════════════════ -->
        <f:content>
            <l:VerticalLayout id="_IDGenVerticalLayout11" width="100%" class="sapUiSmallMargin">

                <!-- Empty state -->
                <VBox id="_IDGenVBox43" visible="{= !${apv>/ui/dataLoaded}}" alignItems="Center" class="sapUiLargeMarginTop">
                    <core:Icon id="_IDGenIcon5" src="sap-icon://approvals" size="4rem" color="#c2c2c2" class="sapUiSmallMarginBottom"/>
                    <Title id="_IDGenTitle19" text="No Requests Loaded" level="H4"/>
                    <Text id="_IDGenText" text="Click 'Load All' to load all approval requests, or apply filters and click Go." class="sapUiSmallMarginTop" textAlign="Center"/>
                    <Button id="_IDGenButton27" text="Load All Requests" type="Emphasized" icon="sap-icon://search" press=".onLoadAll" class="sapUiMediumMarginTop"/>
                </VBox>

                <!-- ══ REQUESTS TABLE ══ -->
                <Toolbar id="_IDGenToolbar11" visible="{apv>/ui/dataLoaded}">
                    <Title id="_IDGenTitle20" text="Approval Requests" level="H4"/>
                    <ObjectStatus id="_IDGenObjectStatus53" text="{= ${apv>/filteredRequests}.length + ' request(s)'}" state="Information" class="sapUiSmallMarginBegin"/>
                    <ToolbarSpacer id="_IDGenToolbarSpacer15"/>
                    <Button id="_IDGenButton28" text="Approve Selected" type="Accept" icon="sap-icon://sys-enter-2" press=".onBulkApprove" class="sapUiSmallMarginEnd"/>
                    <Button id="_IDGenButton29" text="Reject Selected"  type="Reject" icon="sap-icon://sys-cancel-2" press=".onBulkReject"/>
                </Toolbar>

                <table:Table
                    id="requestsTable"
                    rows="{apv>/filteredRequests}"
                    selectionMode="MultiToggle"
                    alternateRowColors="true"
                    visibleRowCount="5"
                    rowHeight="52"
                    visible="{apv>/ui/dataLoaded}"
                    busy="{apv>/ui/busy}"
                    enableBusyIndicator="true"
                    rowSelectionChange=".onTableSelectionChange"
                    class="sapUiSmallMarginBottom">

                    <table:Column id="_IDGenColumn44" width="5rem" hAlign="Center" label="Priority">
                        <Label id="_IDGenLabel104" text="Priority"/>
                        <table:template>
                            <ObjectStatus id="_IDGenObjectStatus54"
                                text="{apv>priority}"
                                state="{= ${apv>priority} === 'HIGH' ? 'Error' : ${apv>priority} === 'MEDIUM' ? 'Warning' : 'None' }"
                                icon="{= ${apv>priority} === 'HIGH' ? 'sap-icon://warning' : '' }"/>
                        </table:template>
                    </table:Column>

                    <table:Column id="_IDGenColumn45" width="9rem" label="Request ID">
                        <Label id="_IDGenLabel105" text="Request ID"/>
                        <table:template>
                            <Link id="_IDGenLink" text="{apv>requestId}" press=".onRequestIdPress" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column id="_IDGenColumn46" width="8rem" label="Type">
                        <Label id="_IDGenLabel106" text="Type"/>
                        <table:template>
                            <ObjectStatus id="_IDGenObjectStatus55"
                                text="{apv>typeLabel}"
                                state="{= ${apv>type} === 'REDUCTION' ? 'Warning' : 'Information' }"
                                icon="{= ${apv>type} === 'REDUCTION' ? 'sap-icon://trend-down' : 'sap-icon://document' }"/>
                        </table:template>
                    </table:Column>

                    <table:Column id="_IDGenColumn47" width="14rem" label="Customer">
                        <Label id="_IDGenLabel107" text="Customer"/>
                        <table:template>
                            <VBox id="_IDGenVBox44">
                                <Text id="_IDGenText58" text="{apv>customer}" wrapping="false"/>
                                <Text id="_IDGenText59" text="{apv>salesOffice}" wrapping="false"/>
                            </VBox>
                        </table:template>
                    </table:Column>

                    <table:Column id="_IDGenColumn48" width="11rem" label="Contract">
                        <Label id="_IDGenLabel108" text="Contract"/>
                        <table:template>
                            <VBox id="_IDGenVBox45">
                                <Text id="_IDGenText60" text="{apv>contract}" wrapping="false"/>
                                <ObjectStatus id="_IDGenObjectStatus56" text="{apv>material}" state="Information" style="font-size:11px;"/>
                            </VBox>
                        </table:template>
                    </table:Column>

                    <table:Column id="_IDGenColumn49" width="8rem" hAlign="End" label="AACQ">
                        <Label id="_IDGenLabel109" text="AACQ"/>
                        <table:template>
                            <ObjectNumber id="_IDGenObjectNumber7" number="{apv>aacq}" unit="{apv>uom}"/>
                        </table:template>
                    </table:Column>

                    <table:Column id="_IDGenColumn50" width="10rem" label="Submitted On">
                        <Label id="_IDGenLabel110" text="Submitted On"/>
                        <table:template>
                            <VBox id="_IDGenVBox46">
                                <Text id="_IDGenText61" text="{apv>submittedOn}" wrapping="false"/>
                                <Text id="_IDGenText62"
                                    text="{= ${apv>daysWaiting} > 0 ? ${apv>daysWaiting} + ' day(s) waiting' : ''}"
                                    wrapping="false"
                                    />
                            </VBox>
                        </table:template>
                    </table:Column>

                    <table:Column id="_IDGenColumn51" width="11rem" label="Status">
                        <Label id="_IDGenLabel111" text="Status"/>
                        <table:template>
                            <ObjectStatus id="_IDGenObjectStatus57"
                                text="{apv>statusText}"
                                state="{apv>statusState}"
                                icon="{= ${apv>status} === 'APPROVED' ? 'sap-icon://accept'  :
                                          ${apv>status} === 'REJECTED' ? 'sap-icon://decline' :
                                                                          'sap-icon://pending'  }"/>
                        </table:template>
                    </table:Column>

                    <table:Column id="_IDGenColumn52" width="16rem" label="Actions">
                        <Label id="_IDGenLabel112" text="Actions"/>
                        <table:template>
                            <HBox id="_IDGenHBox22" alignItems="Center">
                                <Button id="_IDGenButton30" text="Review"  type="Ghost"  icon="sap-icon://display"       press=".onReviewRequest"  class="sapUiTinyMarginEnd"/>
                                <Button id="_IDGenButton31" text="Approve" type="Accept" icon="sap-icon://sys-enter-2"   press=".onApproveInline"
                                    visible="{= ${apv>status} === 'PENDING'}" class="sapUiTinyMarginEnd"/>
                                <Button id="_IDGenButton32" text="Reject"  type="Reject" icon="sap-icon://sys-cancel-2"  press=".onRejectInline"
                                    visible="{= ${apv>status} === 'PENDING'}"/>
                            </HBox>
                        </table:template>
                    </table:Column>

                </table:Table>

                <!-- ══ DETAIL PANEL ══ -->
                <Panel
                    id="detailPanel"
                    visible="{apv>/ui/detailVisible}"
                    expandable="true"
                    expanded="true"
                    backgroundDesign="Solid"
                    class="sapUiSmallMarginBottom">

                    <headerToolbar>
                        <Toolbar id="_IDGenToolbar12">
                            <Title id="_IDGenTitle21" text="Request Detail – {apv>/selectedRequest/requestId}" level="H5"/>
                            <ToolbarSpacer id="_IDGenToolbarSpacer18"/>
                            <ObjectStatus id="_IDGenObjectStatus58"
                                text="{apv>/selectedRequest/statusText}"
                                state="{apv>/selectedRequest/statusState}"
                                icon="{= ${apv>/selectedRequest/status} === 'APPROVED' ? 'sap-icon://accept'  :
                                          ${apv>/selectedRequest/status} === 'REJECTED' ? 'sap-icon://decline' : 'sap-icon://pending' }"/>
                        </Toolbar>
                    </headerToolbar>

                    <content>
                        <!-- Request ObjectHeader -->
                        <ObjectHeader id="_IDGenObjectHeader"
                            title="{apv>/selectedRequest/customer}"
                            number="{apv>/selectedRequest/aacq}"
                            numberUnit="{apv>/selectedRequest/uom}"
                            intro="{apv>/selectedRequest/contract} · {apv>/selectedRequest/material} · {apv>/selectedRequest/typeLabel}"
                            backgroundDesign="Solid">
                            <attributes>
                                <ObjectAttribute id="_IDGenObjectAttribute6" title="Industry"     text="{apv>/selectedRequest/industry}"/>
                                <ObjectAttribute id="_IDGenObjectAttribute7" title="Sales Office"  text="{apv>/selectedRequest/salesOffice}"/>
                                <ObjectAttribute id="_IDGenObjectAttribute8" title="Submitted By"  text="{apv>/selectedRequest/submittedBy}"/>
                                <ObjectAttribute id="_IDGenObjectAttribute9" title="Submitted On"  text="{apv>/selectedRequest/submittedOn}"/>
                            </attributes>
                            <statuses>
                                <ObjectStatus id="_IDGenObjectStatus59" title="Priority" text="{apv>/selectedRequest/priority}"
                                    state="{= ${apv>/selectedRequest/priority} === 'HIGH' ? 'Error' : ${apv>/selectedRequest/priority} === 'MEDIUM' ? 'Warning' : 'None' }"/>
                                <ObjectStatus id="_IDGenObjectStatus60" title="Days Waiting" text="{apv>/selectedRequest/daysWaiting} day(s)"
                                    state="{= ${apv>/selectedRequest/daysWaiting} >= 5 ? 'Error' : ${apv>/selectedRequest/daysWaiting} >= 3 ? 'Warning' : 'None' }"/>
                            </statuses>
                        </ObjectHeader>

                        <!-- Contract Info Grid -->
                        <l:Grid id="_IDGenGrid2" defaultSpan="XL2 L2 M4 S6" class="sapUiSmallMarginBegin sapUiSmallMarginBottom">
                            <l:content>
                                <VBox id="_IDGenVBox47"><Label id="_IDGenLabel113" text="ACQ" design="Bold"/><Text id="_IDGenText63" text="{apv>/selectedRequest/contractInfo/acq} {apv>/selectedRequest/uom}"/></VBox>
                                <VBox id="_IDGenVBox48"><Label id="_IDGenLabel114" text="AACQ" design="Bold"/><Text id="_IDGenText64" text="{apv>/selectedRequest/aacq} {apv>/selectedRequest/uom}"/></VBox>
                                <VBox id="_IDGenVBox49"><Label id="_IDGenLabel115" text="Upward Flex" design="Bold"/><Text id="_IDGenText65" text="+{apv>/selectedRequest/contractInfo/upwardFlex}%"/></VBox>
                                <VBox id="_IDGenVBox50"><Label id="_IDGenLabel116" text="Downward Flex" design="Bold"/><Text id="_IDGenText66" text="-{apv>/selectedRequest/contractInfo/downwardFlex}%"/></VBox>
                                <VBox id="_IDGenVBox51"><Label id="_IDGenLabel117" text="Make-Up Gas" design="Bold"/><Text id="_IDGenText67" text="{apv>/selectedRequest/contractInfo/makeUpGas} {apv>/selectedRequest/uom}"/></VBox>
                                <VBox id="_IDGenVBox52"><Label id="_IDGenLabel118" text="TOP %" design="Bold"/><Text id="_IDGenText68" text="{apv>/selectedRequest/contractInfo/topPct}%"/></VBox>
                                <VBox id="_IDGenVBox53"><Label id="_IDGenLabel119" text="S/D Days" design="Bold"/><Text id="_IDGenText69" text="{apv>/selectedRequest/contractInfo/sdDays} days"/></VBox>
                                <VBox id="_IDGenVBox54"><Label id="_IDGenLabel120" text="Reduction Applied" design="Bold">
                                    </Label><ObjectStatus id="_IDGenObjectStatus61"
                                        text="{= ${apv>/selectedRequest/reductionApplied} ? 'Yes' : 'No'}"
                                        state="{= ${apv>/selectedRequest/reductionApplied} ? 'Warning' : 'None' }"
                                        icon="{= ${apv>/selectedRequest/reductionApplied} ? 'sap-icon://trend-down' : '' }"/>
                                </VBox>
                            </l:content>
                        </l:Grid>

                        <!-- Reduction Details (shown if reduction applied) -->
                        <MessageStrip id="_IDGenMessageStrip2"
                            visible="{apv>/selectedRequest/reductionApplied}"
                            text="Reduction: {apv>/selectedRequest/reductionDetails/reductionPct}% applied from {apv>/selectedRequest/reductionDetails/monthFrom} to {apv>/selectedRequest/reductionDetails/monthTo} · Reduced Qty: {apv>/selectedRequest/reductionDetails/totalReducedQty} {apv>/selectedRequest/uom} · Re-apportioned across {apv>/selectedRequest/reductionDetails/reapportionedAcross} months · AACQ unchanged: {apv>/selectedRequest/aacq} {apv>/selectedRequest/uom}"
                            type="Warning"
                            showIcon="true"
                            class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiSmallMarginBottom"/>

                        <!-- Quarterly Summary -->
                        <Title id="_IDGenTitle22" text="Quarterly Compliance Summary" level="H5" class="sapUiSmallMarginBegin sapUiSmallMarginTop"/>
                        <HBox id="_IDGenHBox23" wrap="Wrap" class="sapUiSmallMargin">
                            <VBox id="_IDGenVBox55" class="sapUiSmallMarginEnd" width="165px">
                                <Label id="_IDGenLabel121" text="Q1 (Jan-Mar)" design="Bold"/>
                                <ObjectStatus id="_IDGenObjectStatus62" text="{apv>/selectedRequest/quarterlyTotals/q1} ({apv>/selectedRequest/quarterlyTotals/q1Pct}%)" state="{apv>/selectedRequest/quarterlyTotals/q1State}"/>
                                <Text id="_IDGenText70" text="Limit: {apv>/selectedRequest/quarterlyLimits/q1Limit}%" />
                            </VBox>
                            <VBox id="_IDGenVBox56" class="sapUiSmallMarginEnd" width="165px">
                                <Label id="_IDGenLabel122" text="Q2 (Apr-Jun)" design="Bold"/>
                                <ObjectStatus id="_IDGenObjectStatus63" text="{apv>/selectedRequest/quarterlyTotals/q2} ({apv>/selectedRequest/quarterlyTotals/q2Pct}%)" state="{apv>/selectedRequest/quarterlyTotals/q2State}"/>
                                <Text id="_IDGenText71" text="Limit: {apv>/selectedRequest/quarterlyLimits/q2Limit}%" />
                            </VBox>
                            <VBox id="_IDGenVBox57" class="sapUiSmallMarginEnd" width="165px">
                                <Label id="_IDGenLabel123" text="Q3 (Jul-Sep)" design="Bold"/>
                                <ObjectStatus id="_IDGenObjectStatus64" text="{apv>/selectedRequest/quarterlyTotals/q3} ({apv>/selectedRequest/quarterlyTotals/q3Pct}%)" state="{apv>/selectedRequest/quarterlyTotals/q3State}"/>
                                <Text id="_IDGenText72" text="Limit: {apv>/selectedRequest/quarterlyLimits/q3Limit}%" />
                            </VBox>
                            <VBox id="_IDGenVBox58" width="165px">
                                <Label id="_IDGenLabel124" text="Q4 (Oct-Dec)" design="Bold"/>
                                <ObjectStatus id="_IDGenObjectStatus65" text="{apv>/selectedRequest/quarterlyTotals/q4} ({apv>/selectedRequest/quarterlyTotals/q4Pct}%)" state="{apv>/selectedRequest/quarterlyTotals/q4State}"/>
                                <Text id="_IDGenText73" text="Limit: {apv>/selectedRequest/quarterlyLimits/q4Limit}%" />
                            </VBox>
                        </HBox>

                        <!-- Monthly plan table (read-only, single row) -->
                        <Title id="_IDGenTitle23" text="Month-wise Planned Quantities" level="H5" class="sapUiSmallMarginBegin sapUiMediumMarginTop"/>
                        <table:Table
                            id="monthlyDetailTable"
                            rows="{apv>/selectedRequest/monthlyRow}"
                            selectionMode="None"
                            visibleRowCount="1"
                            rowHeight="44"
                            class="sapUiSmallMargin">
                            <table:columns>
                                <table:Column id="_IDGenColumn53" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel125" text="Jan"/><table:template><ObjectStatus id="_IDGenObjectStatus66" text="{jan}" state="{janState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn54" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel126" text="Feb"/><table:template><ObjectStatus id="_IDGenObjectStatus67" text="{feb}" state="{febState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn55" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel127" text="Mar"/><table:template><ObjectStatus id="_IDGenObjectStatus68" text="{mar}" state="{marState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn56" width="6.5rem" hAlign="Center"><Label id="_IDGenLabel128" text="Q1 Total"/><table:template><ObjectStatus id="_IDGenObjectStatus69" text="{q1}" state="{q1State}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn57" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel129" text="Apr"/><table:template><ObjectStatus id="_IDGenObjectStatus70" text="{apr}" state="{aprState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn58" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel130" text="May"/><table:template><ObjectStatus id="_IDGenObjectStatus71" text="{may}" state="{mayState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn59" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel131" text="Jun"/><table:template><ObjectStatus id="_IDGenObjectStatus72" text="{jun}" state="{junState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn60" width="6.5rem" hAlign="Center"><Label id="_IDGenLabel132" text="Q2 Total"/><table:template><ObjectStatus id="_IDGenObjectStatus73" text="{q2}" state="{q2State}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn61" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel133" text="Jul"/><table:template><ObjectStatus id="_IDGenObjectStatus74" text="{jul}" state="{julState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn62" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel134" text="Aug"/><table:template><ObjectStatus id="_IDGenObjectStatus75" text="{aug}" state="{augState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn63" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel135" text="Sep"/><table:template><ObjectStatus id="_IDGenObjectStatus76" text="{sep}" state="{sepState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn64" width="6.5rem" hAlign="Center"><Label id="_IDGenLabel136" text="Q3 Total"/><table:template><ObjectStatus id="_IDGenObjectStatus77" text="{q3}" state="{q3State}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn65" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel137" text="Oct"/><table:template><ObjectStatus id="_IDGenObjectStatus78" text="{oct}" state="{octState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn66" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel138" text="Nov"/><table:template><ObjectStatus id="_IDGenObjectStatus79" text="{nov}" state="{novState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn67" width="5.5rem" hAlign="Center"><Label id="_IDGenLabel139" text="Dec"/><table:template><ObjectStatus id="_IDGenObjectStatus80" text="{dec}" state="{decState}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn68" width="6.5rem" hAlign="Center"><Label id="_IDGenLabel140" text="Q4 Total"/><table:template><ObjectStatus id="_IDGenObjectStatus81" text="{q4}" state="{q4State}"/></table:template></table:Column>
                                <table:Column id="_IDGenColumn69" width="7.5rem" hAlign="Center"><Label id="_IDGenLabel141" text="Annual"/><table:template><ObjectNumber id="_IDGenObjectNumber8" number="{annual}" emphasized="true"/></table:template></table:Column>
                            </table:columns>
                        </table:Table>

                        <!-- Workflow Progress Tracker -->
                        <Title id="_IDGenTitle24" text="Approval Workflow Progress" level="H5" class="sapUiSmallMarginBegin sapUiMediumMarginTop"/>
                        <HBox id="_IDGenHBox24" class="sapUiSmallMargin" wrap="Wrap" alignItems="Center">
                            <core:Fragment fragmentName="com.ingenx.annualplan.fragments.WorkflowTracker" type="XML"/>
                        </HBox>

                        <!-- Previous approver comment (if any) -->
                        <MessageStrip
                            id="prevCommentStrip"
                            text="Approver Comment: {apv>/selectedRequest/approverComment}"
                            type="{= ${apv>/selectedRequest/status} === 'REJECTED' ? 'Error' : 'Success' }"
                            showIcon="true"
                            visible="{= !!${apv>/selectedRequest/approverComment}}"
                            class="sapUiSmallMargin"/>

                        <!-- Approver comment input (pending only) -->
                        <l:VerticalLayout id="_IDGenVerticalLayout14"
                            width="100%"
                            class="sapUiSmallMargin"
                            visible="{= ${apv>/selectedRequest/status} === 'PENDING'}">
                            <Label id="_IDGenLabel142" text="Approver Comments" design="Bold" class="sapUiSmallMarginBottom"/>
                            <TextArea
                                id="approverCommentInput"
                                value="{apv>/selectedRequest/approverComment}"
                                placeholder="Enter comments or reason (required when rejecting)…"
                                rows="3"
                                width="100%"
                                growing="true"/>
                        </l:VerticalLayout>

                        <!-- Post-approval processing notice -->
                        <MessageStrip id="_IDGenMessageStrip6"
                            text="Upon approval: System will send notifications to Customer and Zonal Office. Contract quantities (ACQ, MCQ) will be updated automatically. DCQ will be recalculated for each month."
                            type="Information"
                            showIcon="true"
                            visible="{= ${apv>/selectedRequest/status} === 'PENDING'}"
                            class="sapUiSmallMargin"/>

                    </content>

                    <!-- Detail Panel Footer Actions -->
                   
                </Panel>
                

            </l:VerticalLayout>
            
        </f:content>
         <f:footer>
                        <Toolbar id="_IDGenToolbar13">
                            <ToolbarSpacer id="_IDGenToolbarSpacer19"/>
                            <Button id="_IDGenButton33"
                                text="Approve"
                                type="Accept"
                                icon="sap-icon://sys-enter-2"
                                press=".onApproveDetail"
                                visible="{= ${apv>/selectedRequest/status} === 'PENDING'}"
                                class="sapUiSmallMarginEnd"/>
                            <Button id="_IDGenButton34"
                                text="Reject with Comment"
                                type="Reject"
                                icon="sap-icon://sys-cancel-2"
                                press=".onRejectDetail"
                                visible="{= ${apv>/selectedRequest/status} === 'PENDING'}"/>
                        </Toolbar>
                    </f:footer>

    </f:DynamicPage>
</mvc:View>
