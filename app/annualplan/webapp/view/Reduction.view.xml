
    <mvc:View
    controllerName="com.ingenx.annualplan.controller.Reduction"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:tnt="sap.tnt"
    xmlns:l="sap.ui.layout"
    xmlns:table="sap.ui.table"
    xmlns:core="sap.ui.core"
    displayBlock="true">

   <Page showHeader="false">
   
     <ScrollContainer id="reduction_Scrollcontainer" vertical="true">
      <tnt:ToolHeader id="reduction__MappingshellOnlyMandatoryControls" class="sapUiTinyMargin header_nav">
            <Button icon="sap-icon://nav-back" press="onPressNavBack"/>
            <Title id="reduction__Mapping_Title" textAlign="Center" text="Reduction" wrapping="false">
            </Title>
            <ToolbarSpacer id="reduction__Mapping_ToolbarSpacer" />
        </tnt:ToolHeader>

        <!-- filter area -->
        <HBox class="filterArea" visible="false">
             <HBox class="headerSelectArea">
                <!-- material -->
                <VBox class="sapUiSmallMarginEnd">
                    <Label id="_IDGenLabel" text="Material"    design="Bold" width="72px"/>
                        <Select id="selMaterial"    width="200px" selectedKey="{red>/filters/material}">
                            <items>
                                <core:Item id="_IDGenItem19" key="" text="All Materials"/>
                                <core:Item id="_IDGenItem20" key="RLNG" text="RLNG"/>
                                <core:Item id="_IDGenItem21" key="PNG"  text="PNG"/>
                                <core:Item id="_IDGenItem22" key="CNG"  text="CNG"/>
                                <core:Item id="_IDGenItem23" key="APM"  text="APM"/>
                            </items>
                        </Select>
                </VBox>

                <!-- sales office -->
                <VBox class="sapUiSmallMarginEnd">
                    <Label id="_IDGenLabel74" text="Sales Office" design="Bold" width="82px"/>
                        <Select id="selSalesOffice" width="200px" selectedKey="{red>/filters/salesOffice}">
                            <items>
                                <core:Item id="_IDGenItem24" key=""      text="All Sales Offices"/>
                                <core:Item id="_IDGenItem25" key="NORTH" text="North Zone - Delhi"/>
                                <core:Item id="_IDGenItem26" key="WEST"  text="West Zone - Mumbai"/>
                                <core:Item id="_IDGenItem27" key="SOUTH" text="South Zone - Chennai"/>
                                <core:Item id="_IDGenItem28" key="EAST"  text="East Zone - Kolkata"/>
                            </items>
                        </Select>
                </VBox>

                <!-- Customer -->
                <VBox class="sapUiSmallMarginEnd">
                   <Label id="_IDGenLabel75" text="Customer"    design="Bold" width="72px"/>
                        <Select id="selCustomer"    width="200px" selectedKey="{red>/filters/customer}">
                            <items>
                                <core:Item id="_IDGenItem29" key=""           text="All Customers"/>
                                <core:Item id="_IDGenItem30" key="CUST-1001"  text="ABC Power Ltd"/>
                                <core:Item id="_IDGenItem31" key="CUST-1002"  text="XYZ Fertilizer Co."/>
                                <core:Item id="_IDGenItem32" key="CUST-1004"  text="LMN Energy Ltd"/>
                                <core:Item id="_IDGenItem33" key="CUST-1005"  text="DEF Textiles Pvt"/>
                            </items>
                        </Select>
                </VBox>

                <!-- Contract -->
                <VBox class="sapUiSmallMarginEnd">
                   <Label id="_IDGenLabel76" text="Contract"    design="Bold" width="65px"/>
                        <Select id="selContract"    width="200px" selectedKey="{red>/filters/contract}">
                            <items>
                                <core:Item id="_IDGenItem34" key=""             text="All Contracts"/>
                                <core:Item id="_IDGenItem35" key="CTR-2025-001" text="CTR-2025-001"/>
                                <core:Item id="_IDGenItem36" key="CTR-2025-002" text="CTR-2025-002"/>
                                <core:Item id="_IDGenItem37" key="CTR-2025-004" text="CTR-2025-004"/>
                                <core:Item id="_IDGenItem38" key="CTR-2025-005" text="CTR-2025-005"/>
                            </items>
                        </Select>
                </VBox>

                <!-- Industry -->
                <VBox class="sapUiSmallMarginEnd">
                    <Label id="_IDGenLabel77" text="Industry"    design="Bold" width="62px"/>
                        <Select id="selIndustry"    width="200px" selectedKey="{red>/filters/industry}">
                            <items>
                                <core:Item id="_IDGenItem39" key=""           text="All Industries"/>
                                <core:Item id="_IDGenItem40" key="POWER"      text="Power"/>
                                <core:Item id="_IDGenItem41" key="FERTILIZER" text="Fertilizer"/>
                                <core:Item id="_IDGenItem42" key="INDUSTRIAL" text="Industrial"/>
                                <core:Item id="_IDGenItem43" key="TEXTILE"    text="Textile"/>
                                <core:Item id="_IDGenItem44" key="CHEMICAL"   text="Chemical"/>
                            </items>
                        </Select>
                </VBox>
                <!-- Button -->
                <VBox> 
                    <Label text=""/>
                   <HBox>
                       <Button id="_IDGenButton19" text="Go"    type="Emphasized" icon="sap-icon://search" press=".onApplyFilter"/>
                        <Button id="_IDGenButton20" text="Clear" type="Ghost" press=".onClearFilter" class="sapUiTinyMarginBegin"/>
                   </HBox>
                </VBox>
             </HBox>
        </HBox>


        <!-- Body Content -->
        <VBox class="filterArea sapUiSmallMarginTop">
                <Toolbar id="_IDGenToolbar8">
                    <Title id="_IDGenTitle13" text="Step 1 - Select an Approved Annual Plan" level="H4"/>
                    <ObjectStatus id="_IDGenObjectStatus31" text="{= ${red>/filteredRecords}.length + ' plan(s) found'}" state="Information" class="sapUiSmallMarginBegin" visible="{red>/ui/dataLoaded}"/>
                </Toolbar>

                <VBox id="_IDGenVBox33" visible="{= !${red>/ui/dataLoaded}}" alignItems="Center" class="sapUiMediumMarginTop sapUiMediumMarginBottom">
                    <core:Icon id="_IDGenIcon3" src="sap-icon://curriculum" size="3.5rem" color="#c2c2c2" class="sapUiSmallMarginBottom"/>
                    <Title id="_IDGenTitle14" text="No Plans Loaded" level="H5"/>
                    <Text id="_IDGenText47" text="Please go back to the Dashboard screen and press the Reduction button to view the records." class="sapUiSmallMarginTop"/>
                </VBox>
        
          <table:Table
                    id="planListTable"
                    rows="{red>/filteredRecords}"
                    selectionMode="Single"
                    selectionBehavior="Row"
                    alternateRowColors="true"
                    visibleRowCount="4"
                    rowHeight="48"
                    visible="{red>/ui/dataLoaded}"
                    rowSelectionChange=".onPlanRowSelect"
                    busy="{red>/ui/busy}"
                    enableBusyIndicator="true"
                    class="sapUiSmallMarginBottom zonalPlanTable">

                    <table:Column id="_IDGenColumn31" label="Customer">
                        <Label id="_IDGenLabel78" text="Customer"/>
                        <table:template>
                            <VBox id="_IDGenVBox34">
                                <Text id="_IDGenText48" text="{red>customer}" wrapping="false"/>
                                <Text id="_IDGenText49" text="{red>salesOffice}" wrapping="false"/>
                            </VBox>
                        </table:template>
                    </table:Column>
                    <table:Column id="_IDGenColumn32"  label="Contract">
                        <Label id="_IDGenLabel79" text="Contract"/>
                        <table:template><Text id="_IDGenText50" text="{red>contract}" wrapping="false"/></table:template>
                    </table:Column>
                    <table:Column id="_IDGenColumn33"  label="Material">
                        <Label id="_IDGenLabel80" text="Material"/>
                        <table:template><ObjectStatus id="_IDGenObjectStatus32" text="{red>material}" state="Information"/></table:template>
                    </table:Column>
                    <table:Column id="_IDGenColumn34" label="Industry">
                        <Label id="_IDGenLabel81" text="Industry"/>
                        <table:template><Text id="_IDGenText51" text="{red>industry}" wrapping="false"/></table:template>
                    </table:Column>
                    <table:Column id="_IDGenColumn35" hAlign="End" label="AACQ">
                        <Label id="_IDGenLabel82" text="AACQ"/>
                        <table:template><ObjectNumber id="_IDGenObjectNumber4" number="{red>aacq}" unit="{red>uom}"/></table:template>
                    </table:Column>
                    <table:Column id="_IDGenColumn36" label="Status">
                        <Label id="_IDGenLabel83" text="Status"/>
                        <table:template><ObjectStatus id="_IDGenObjectStatus33" text="{red>status}" state="{red>statusState}" icon="sap-icon://accept"/></table:template>
                    </table:Column>
          </table:Table>
          </VBox>

           <Panel id="reductionInputPanel" width="99%" visible="{red>/ui/planSelected}" backgroundDesign="Solid" class="sapUiSmallMarginBottom filterArea">
                    <headerToolbar>
                        <Toolbar id="_IDGenToolbar9">
                            <Title id="_IDGenTitle15" text="Step 2 - Define Reduction" level="H5"/>
                            <ToolbarSpacer id="_IDGenToolbarSpacer16"/>
                            <ObjectStatus id="_IDGenObjectStatus34" text="{red>/selectedPlan/customer}"                              state="None"        class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="_IDGenObjectStatus35" text="{red>/selectedPlan/contract}"                              state="Information" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="_IDGenObjectStatus36" text="{red>/selectedPlan/material}"                              state="Information" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="_IDGenObjectStatus37" text="AACQ: {red>/selectedPlan/aacq} {red>/selectedPlan/uom}" state="Success"     icon="sap-icon://locked"/>
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <l:VerticalLayout id="_IDGenVerticalLayout12" width="100%" class="sapUiSmallMargin">
                            <HBox id="_IDGenHBox14" alignItems="Center" class="sapUiSmallMarginBottom">
                                <Label id="_IDGenLabel84" text="Reduction Scope:" design="Bold" width="130px"/>
                                <SegmentedButton id="reductionMode" selectedKey="{red>/reduction/mode}" selectionChange=".onModeChange">
                                    <items>
                                        <SegmentedButtonItem id="_IDGenSegmentedButtonItem" key="SINGLE" text="Single Month" icon="sap-icon://calendar"/>
                                        <SegmentedButtonItem id="_IDGenSegmentedButtonItem1" key="RANGE"  text="Month Range"  icon="sap-icon://date-time"/>
                                    </items>
                                </SegmentedButton>
                            </HBox>
                            <HBox id="_IDGenHBox15" wrap="Wrap" justifyContent="End" class="sapUiSmallMarginBottom">
                                <VBox id="_IDGenVBox35" class="sapUiSmallMarginEnd" width="160px">
                                    <Label id="_IDGenLabel85" text="{= ${red>/reduction/mode} === 'RANGE' ? 'Month From *' : 'Month *'}" design="Bold"/>
                                    <Select id="selMonthFrom" width="100%" selectedKey="{red>/reduction/monthFrom}" change=".onReductionInputChange">
                                        <items>
                                            <core:Item id="_IDGenItem45" key="jan" text="January"/>   <core:Item id="_IDGenItem46" key="feb" text="February"/>
                                            <core:Item id="_IDGenItem47" key="mar" text="March"/>     <core:Item id="_IDGenItem48" key="apr" text="April"/>
                                            <core:Item id="_IDGenItem49" key="may" text="May"/>       <core:Item id="_IDGenItem50" key="jun" text="June"/>
                                            <core:Item id="_IDGenItem51" key="jul" text="July"/>      <core:Item id="_IDGenItem52" key="aug" text="August"/>
                                            <core:Item id="_IDGenItem53" key="sep" text="September"/> <core:Item id="_IDGenItem54" key="oct" text="October"/>
                                            <core:Item id="_IDGenItem55" key="nov" text="November"/>  <core:Item id="_IDGenItem56" key="dec" text="December"/>
                                        </items>
                                    </Select>
                                </VBox>
                                <VBox id="_IDGenVBox36" class="sapUiSmallMarginEnd" width="160px" visible="{= ${red>/reduction/mode} === 'RANGE'}">
                                    <Label id="_IDGenLabel86" text="Month To *" design="Bold"/>
                                    <Select id="selMonthTo" width="100%" selectedKey="{red>/reduction/monthTo}" change=".onReductionInputChange">
                                        <items>
                                            <core:Item id="_IDGenItem57" key="jan" text="January"/>   <core:Item id="_IDGenItem58" key="feb" text="February"/>
                                            <core:Item id="_IDGenItem59" key="mar" text="March"/>     <core:Item id="_IDGenItem60" key="apr" text="April"/>
                                            <core:Item id="_IDGenItem61" key="may" text="May"/>       <core:Item id="_IDGenItem62" key="jun" text="June"/>
                                            <core:Item id="_IDGenItem63" key="jul" text="July"/>      <core:Item id="_IDGenItem64" key="aug" text="August"/>
                                            <core:Item id="_IDGenItem65" key="sep" text="September"/> <core:Item id="_IDGenItem66" key="oct" text="October"/>
                                            <core:Item id="_IDGenItem67" key="nov" text="November"/>  <core:Item id="_IDGenItem68" key="dec" text="December"/>
                                        </items>
                                    </Select>
                                </VBox>
                                <VBox id="_IDGenVBox37" class="sapUiSmallMarginEnd" width="180px">
                                    <Label id="_IDGenLabel87" text="Reduction % *" design="Bold"/>
                                    <StepInput id="siReductionPct" value="{red>/reduction/reductionPct}"
                                        min="1" max="100" step="1" displayValuePrecision="0"
                                        description="%" width="100%"
                                        change=".onReductionInputChange"/>
                                </VBox>
                                <VBox id="_IDGenVBox38" width="165px">
                                    <Label id="_IDGenLabel88" text=" "/>
                                    <Button id="_IDGenButton21" text="Preview Reduction" type="Emphasized" icon="sap-icon://show" press=".onPreviewReduction" width="100%"/>
                                </VBox>
                            </HBox>
                            <MessageStrip id="_IDGenMessageStrip3"
                                text="Reduced quantity is re-apportioned equally across the remaining months. AACQ remains unchanged."
                                type="Information" showIcon="true"/>
                        </l:VerticalLayout>
                    </content>
                </Panel>

                 <Panel id="previewPanel" visible="{red>/ui/previewReady}" width="99%" backgroundDesign="Solid" class="sapUiSmallMarginBottom filterArea">
                    <headerToolbar>
                        <Toolbar id="_IDGenToolbar10">
                            <Title id="_IDGenTitle16" text="Step 3 - Reduction Preview (Read-only)" level="H5"/>
                            <ToolbarSpacer id="_IDGenToolbarSpacer17"/>
                            <ObjectStatus id="_IDGenObjectStatus38" title="Total Reduced"     text="{red>/reduction/totalReducedQty} {red>/selectedPlan/uom}" state="Error"       icon="sap-icon://trend-down"   class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="_IDGenObjectStatus39" title="Re-apportioned"    text="{red>/reduction/reapportionMonthCount} months"           state="Warning"     icon="sap-icon://redistribute" class="sapUiSmallMarginEnd"/>
                            <ObjectStatus id="_IDGenObjectStatus40" title="AACQ Locked"       text="{red>/selectedPlan/aacq} {red>/selectedPlan/uom}"        state="Success"     icon="sap-icon://locked"/>
                        </Toolbar>
                    </headerToolbar>
                    <content>
                        <l:VerticalLayout id="_IDGenVerticalLayout13" width="100%">

                            <!-- Legend strip -->
                            <HBox id="_IDGenHBox16" class="sapUiSmallMarginBegin sapUiSmallMarginTop" alignItems="Center">
                                <ObjectStatus id="_IDGenObjectStatus41" text="Reduced months"       state="Error"   class="sapUiSmallMarginEnd"/>
                                <ObjectStatus id="_IDGenObjectStatus42" text="Re-apportioned months" state="Warning" class="sapUiSmallMarginEnd"/>
                                <ObjectStatus id="_IDGenObjectStatus43" text="Unchanged months"     state="None"    class="sapUiSmallMarginEnd"/>
                                <ObjectStatus id="_IDGenObjectStatus44" text="AACQ preserved"       state="Success"/>
                            </HBox>

                            <!-- Comparison table: all 12 months -->
                            <table:Table
                                id="previewTable"
                                rows="{red>/reduction/previewRows}"
                                selectionMode="None"
                                alternateRowColors="false"
                                visibleRowCount="12"
                                rowHeight="50"
                                class="sapUiSmallMarginTop zonalPlanTable">

                                <table:Column id="_IDGenColumn37" width="9rem" label="Month">
                                    <Label id="_IDGenLabel89" text="Month"/>
                                    <table:template>
                                        <HBox id="_IDGenHBox17" alignItems="Center">
                                            <core:Icon id="_IDGenIcon4"
                                                src="{= ${red>rowType} === 'REDUCED' ? 'sap-icon://trend-down' : ${red>rowType} === 'REAPPORTIONED' ? 'sap-icon://redistribute' : 'sap-icon://less' }"
                                                color="{= ${red>rowType} === 'REDUCED' ? '#bb0000' : ${red>rowType} === 'REAPPORTIONED' ? '#e9730c' : '#8c8c8c' }"
                                                class="sapUiSmallMarginEnd"/>
                                            <Text id="_IDGenText52" text="{red>monthLabel}" wrapping="false"/>
                                        </HBox>
                                    </table:template>
                                </table:Column>

                                <table:Column id="_IDGenColumn38" hAlign="Center" label="Quarter">
                                    <Label id="_IDGenLabel90" text="Quarter"/>
                                    <table:template><Text id="_IDGenText53" text="{red>quarter}"/></table:template>
                                </table:Column>

                                <table:Column id="_IDGenColumn39" hAlign="End" label="Original">
                                    <Label id="_IDGenLabel91" text="Original"/>
                                    <table:template>
                                        <ObjectNumber id="_IDGenObjectNumber5" number="{red>originalQty}" unit="{red>uom}" emphasized="false"/>
                                    </table:template>
                                </table:Column>

                                <table:Column id="_IDGenColumn40" hAlign="Center" label="Change">
                                    <Label id="_IDGenLabel92" text="Change"/>
                                    <table:template>
                                        <ObjectStatus id="_IDGenObjectStatus45" text="{red>changeText}" state="{red>changeState}"/>
                                    </table:template>
                                </table:Column>

                                <table:Column id="_IDGenColumn41" hAlign="End" label="Revised">
                                    <Label id="_IDGenLabel93" text="Revised"/>
                                    <table:template>
                                        <ObjectNumber id="_IDGenObjectNumber6"
                                            number="{red>revisedQty}"
                                            unit="{red>uom}"
                                            emphasized="{= ${red>rowType} !== 'UNCHANGED' }"
                                            state="{= ${red>rowType} === 'REDUCED' ? 'Error' : ${red>rowType} === 'REAPPORTIONED' ? 'Warning' : 'None' }"/>
                                    </table:template>
                                </table:Column>

                                <table:Column id="_IDGenColumn42" hAlign="End" label="Difference">
                                    <Label id="_IDGenLabel94" text="Difference"/>
                                    <table:template>
                                        <ObjectStatus id="_IDGenObjectStatus46" text="{red>diffText}" state="{red>diffState}"/>
                                    </table:template>
                                </table:Column>

                                <table:Column id="_IDGenColumn43" hAlign="Center" label="Type">
                                    <Label id="_IDGenLabel95" text="Type"/>
                                    <table:template>
                                        <ObjectStatus id="_IDGenObjectStatus47"
                                            text="{red>rowTypeLabel}"
                                            state="{= ${red>rowType} === 'REDUCED' ? 'Error' : ${red>rowType} === 'REAPPORTIONED' ? 'Warning' : 'None' }"/>
                                    </table:template>
                                </table:Column>

                            </table:Table>

                            <!-- Revised quarterly summary -->
                            <Title id="_IDGenTitle17" text="Revised Quarterly Summary" level="H5" class="sapUiMediumMarginTop sapUiSmallMarginBegin"/>
                            <HBox id="_IDGenHBox18" wrap="Wrap" class="sapUiSmallMargin">
                                <VBox id="_IDGenVBox39" class="sapUiSmallMarginEnd" width="160px">
                                    <Label id="_IDGenLabel96" text="Q1 (Jan-Mar)" design="Bold"/>
                                    <ObjectStatus id="_IDGenObjectStatus48" text="{red>/reduction/revisedQ1} ({red>/reduction/revisedQ1Pct}%)" state="{red>/reduction/revisedQ1State}"/>
                                    <Text id="_IDGenText54" text="Limit: {red>/selectedPlan/quarterlyLimits/q1Limit}%"/>
                                </VBox>
                                <VBox id="_IDGenVBox40" class="sapUiSmallMarginEnd" width="160px">
                                    <Label id="_IDGenLabel97" text="Q2 (Apr-Jun)" design="Bold"/>
                                    <ObjectStatus id="_IDGenObjectStatus49" text="{red>/reduction/revisedQ2} ({red>/reduction/revisedQ2Pct}%)" state="{red>/reduction/revisedQ2State}"/>
                                    <Text id="_IDGenText55" text="Limit: {red>/selectedPlan/quarterlyLimits/q2Limit}%"/>
                                </VBox>
                                <VBox id="_IDGenVBox41" class="sapUiSmallMarginEnd" width="160px">
                                    <Label id="_IDGenLabel98" text="Q3 (Jul-Sep)" design="Bold"/>
                                    <ObjectStatus id="_IDGenObjectStatus50" text="{red>/reduction/revisedQ3} ({red>/reduction/revisedQ3Pct}%)" state="{red>/reduction/revisedQ3State}"/>
                                    <Text id="_IDGenText56" text="Limit: {red>/selectedPlan/quarterlyLimits/q3Limit}%"/>
                                </VBox>
                                <VBox id="_IDGenVBox42" width="160px">
                                    <Label id="_IDGenLabel99" text="Q4 (Oct-Dec)" design="Bold"/>
                                    <ObjectStatus id="_IDGenObjectStatus51" text="{red>/reduction/revisedQ4} ({red>/reduction/revisedQ4Pct}%)" state="{red>/reduction/revisedQ4State}"/>
                                    <Text id="_IDGenText57" text="Limit: {red>/selectedPlan/quarterlyLimits/q4Limit}%"/>
                                </VBox>
                            </HBox>

                            <!-- AACQ Integrity checks -->
                            <MessageStrip id="_IDGenMessageStrip4"
                                text="AACQ Integrity OK: Revised Annual Total = {red>/reduction/revisedAnnualTotal} {red>/selectedPlan/uom} — matches AACQ exactly. Safe to submit."
                                type="Success" showIcon="true"
                                visible="{red>/reduction/aacqIntact}"
                                class="sapUiSmallMargin"/>
                            <MessageStrip id="_IDGenMessageStrip5"
                                text="AACQ Integrity Error: Revised total does not match AACQ. Please review."
                                type="Error" showIcon="true"
                                visible="{= !${red>/reduction/aacqIntact} &amp;&amp; ${red>/ui/previewReady}}"
                                class="sapUiSmallMargin"/>

                            <HBox id="_IDGenHBox19" justifyContent="End" class="sapUiSmallMargin">
                                <Button id="_IDGenButton23" text="Submit Reduction"  type="Emphasized" icon="sap-icon://paper-plane"   press=".onSubmitReduction" enabled="{red>/reduction/aacqIntact}"/>
                            </HBox>
                        </l:VerticalLayout>
                    </content>
                </Panel>
        </ScrollContainer>
       </Page> 
</mvc:View>

