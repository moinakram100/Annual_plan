<mvc:View controllerName="com.ingenx.annualplan.controller.QuarterlyPercentage"
    xmlns:html="http://www.w3.org/1999/xhtml"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns:f="sap.f"
    xmlns:l = "sap.ui.layout"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:tnt="sap.tnt">
   
     <ScrollContainer id="invoice_Scrollcontainer" vertical="true" height="100%">
      <tnt:ToolHeader id="invoiceByDate__MappingshellOnlyMandatoryControls" class="sapUiTinyMargin header_nav">
            <Title id="invoiceByDate__Mapping_Title" textAlign="Center" text="Quarterly Percentage" wrapping="false">
                <layoutData>
                    <OverflowToolbarLayoutData id="invoiceByDate__Mapping_OverflowToolbarLayoutData" priority="Disappear" />
                </layoutData>
            </Title>
            <ToolbarSpacer id="invoiceByDate__Mapping_ToolbarSpacer" />
           
        </tnt:ToolHeader>


        <l:VerticalLayout id="invoiceByDate__VerticalLayout" width="100%">
            <l:BlockLayout id="invoiceByDate__BlockLayout" background="Dashboard" >

             <l:BlockLayoutRow id="invoiceByDate_BlockLayoutRow3">
                     <l:BlockLayoutCell id="invoiceByDate_BlockLayoutCell3" width="95%">
                          <Label text="Material" class="sapUiTinyMargin" design="Bold"/>
                            <MultiComboBox
                                    id="materialMultiInput"
                                    selectionChange="handleSelectionChange"
                                    selectionFinish="handleSelectionFinish"
                                    width="250px"
                                    items="{
                                        path: 'quarterlyModel>/MaterialVH',
                                        sorter: { path: 'Material' }
                                    }">
                                    <core:Item key="{quarterlyModel>Material}"
                                    text="{quarterlyModel>MaterialDesc}"/>
                                </MultiComboBox>

                          
                     </l:BlockLayoutCell>
             </l:BlockLayoutRow>   
               <l:BlockLayoutRow >
                     <l:BlockLayoutCell  width="95%"> 

                               <Table
                                class="quarterlyTable"                     
                                id="idQuarterTable"
                                headerText="Maintain Quarterly Percentage Limits"
                                visible="true"
                                items="{
                                    path : 'quarterlyModel>/QuarterlyData'
                                }"
                                growing="false"
                                width="100%">

                                <columns>

                                    <Column>
                                        <Text text="Material"/>
                                    </Column>

                                    <Column>
                                        <Text text="Q1 %"/>
                                    </Column>

                                    <Column>
                                        <Text text="Q2 %"/>
                                    </Column>

                                    <Column>
                                        <Text text="Q3 %"/>
                                    </Column>

                                    <Column>
                                        <Text text="Q4 %"/>
                                    </Column>

                                    <!-- <Column>
                                        <Text text="Total" visible="false"/>
                                    </Column> -->

                                </columns>

                                <items>
                                    <ColumnListItem>

                                        <cells>

                                            <!-- Material -->
                                            <Text text="{quarterlyModel>MaterialDesc}"/>

                                            <!-- Q1 -->
                                            <Input
                                                value="{quarterlyModel>Q1_Percentage}"
                                                type="Number"
                                                editable="{quarterlyModel>/UIState/isEditable}"
                                                liveChange=".onPercentageChange"/>

                                            <!-- Q2 -->
                                            <Input
                                                value="{quarterlyModel>Q2_Percentage}"
                                                type="Number"
                                                editable="{quarterlyModel>/UIState/isEditable}"
                                                liveChange=".onPercentageChange"/>

                                            <!-- Q3 -->
                                            <Input
                                                value="{quarterlyModel>Q3_Percentage}"
                                                type="Number"
                                                editable="{quarterlyModel>/UIState/isEditable}"
                                                liveChange=".onPercentageChange"/>

                                            <!-- Q4 -->
                                            <Input
                                                value="{quarterlyModel>Q4_Percentage}"
                                                type="Number"
                                                editable="{quarterlyModel>/UIState/isEditable}"
                                                liveChange=".onPercentageChange"/>

                                            <!-- Total -->
                                            <!-- <Text text="{quarterlyModel>Total}"/> -->

                                        </cells>

                                    </ColumnListItem>
                                </items>

                            </Table>
                            <HBox justifyContent="End" class="sapUiTinyMarginTop">
                               <Button text="Add Row" icon="sap-icon://add" class="sapUiTinyMarginEnd" type="Emphasized"/>
                               <Button text="Save" type="Emphasized"/>
                            </HBox>
               </l:BlockLayoutCell>
             </l:BlockLayoutRow> 
           </l:BlockLayout>
        </l:VerticalLayout>
     </ScrollContainer>

 
</mvc:View>