<mvc:View
    controllerName="com.ingenx.annualplan.controller.Dashboard"
    xmlns="sap.m"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:tnt="sap.tnt"
    xmlns:l="sap.ui.layout"
    xmlns:table="sap.ui.table"
    xmlns:core="sap.ui.core"
    displayBlock="true">
<Page showHeader="false">
     <ScrollContainer id="dashboard_Scrollcontainer" vertical="true">
            <tnt:ToolHeader id="dashboard__MappingshellOnlyMandatoryControls" class="sapUiTinyMargin header_nav">
            <Title id="dashboard__Mapping_Title" textAlign="Center" text="Corporate Dashboard" wrapping="false">
                <layoutData>
                    <OverflowToolbarLayoutData id="dashboard__Mapping_OverflowToolbarLayoutData" priority="Disappear" />
                </layoutData>
            </Title>
            <ToolbarSpacer id="dashboard__Mapping_ToolbarSpacer" />
        </tnt:ToolHeader>

        <!-- filter area -->
        <HBox class="filterArea" visible="{dash>/user/isValid}">
            <HBox class="headerSelectArea">

                <!-- sales office -->
                <VBox class="sapUiSmallMarginEnd">
                    <Label id="dash_Label" text="Sales Office" design="Bold" width="90px"/>
                    <ComboBox
                        items="{
                            path: '/xGMSxSALESOFFICE'
                        }">

                        <core:Item
                            key="{SalesOffice}"
                            text="{SalesOffice}" />

                    </ComboBox>
                </VBox>

                <!-- Material -->
                <VBox class="sapUiSmallMarginEnd">
                    <Label id="dash_Label1" text="Material" design="Bold" width="65px"/>
                    <Input id="dashMaterial"
                    value=""
                    width="200px"
                    showValueHelp="true"
                    valueHelpOnly="true"
                    valueHelpRequest=".onMaterialVH"
                    placeholder="Select Material…"/>
                </VBox>

                <!-- Customer -->
                <VBox class="sapUiSmallMarginEnd">
                    <Label id="dash_Label11" text="Customer" design="Bold" width="70px"/>
                  <Input
                    id="inputCustomerId"
                    value="{ap>/contractSelection/customerId}"
                    width="200px"
                    showValueHelp="true"
                    valueHelpOnly="true"
                    valueHelpRequest=".onCustomerVH"
                    placeholder="Select Customer…"/>
                </VBox>

                <!-- Industry -->
                <VBox class="sapUiSmallMarginEnd">
                    <Label id="dash_Label38" text="Contract" design="Bold" width="65px"/>
                    <Input
                        id="dashContractNo"
                        width="200px"
                        showValueHelp="true"
                        valueHelpRequest=".onContractVH"
                        change=".onContractChange"
                        placeholder="Select Contract…"/>
                </VBox>

                <!-- Buttons -->
                <VBox class="sapUiSmallMarginEnd">
                    <Label id="dashboard_Label38" text="" width="65px"/>
                    <HBox>
                        <Button id="dashboard_Button6" text="Go"    type="Emphasized" icon="sap-icon://search" press=".onApplyFilter"/>
                        <Button id="dashboard_Button7" text="Clear" type="Ghost"      press=".onClearFilter"   class="sapUiTinyMarginBegin"/>
                    </HBox>
                </VBox>

            </HBox>
        </HBox>
        <VBox
    visible="{dash>/user/isLoading}"
    alignItems="Center"
    justifyContent="Center"
    height="400px"
    class="filterArea sapUiTinyMarginTop">
    <BusyIndicator size="2rem" class="sapUiSmallMarginBottom"/>
    <Text text="Verifying user access…" class="sapUiSmallMarginTop"/>
</VBox>
 
<!-- ── Access Denied State ── -->
<VBox
    visible="{= !${dash>/user/isLoading} &amp;&amp; !${dash>/user/isValid} }"
    alignItems="Center"
    justifyContent="Center"
    height="400px"
    class="filterArea sapUiTinyMarginTop">
    <core:Icon
        src="sap-icon://locked"
        size="4rem"
        color="#bb0000"
        class="sapUiSmallMarginBottom"/>
    <Title text="Access Denied" level="H3" class="sapUiSmallMarginBottom"/>
    <Text
        text="{dash>/ui/accessDeniedMsg}"
        textAlign="Center"
        wrapping="true"
        class="sapUiSmallMarginTop sapUiSmallMarginBegin sapUiSmallMarginEnd"/>
    <MessageStrip
        text="Contact your system administrator to configure your access."
        type="Error"
        showIcon="true"
        class="sapUiMediumMarginTop sapUiSmallMarginBegin sapUiSmallMarginEnd"/>
</VBox>

        <!-- No Data State -->
        <VBox
            id="noDataBox"
            visible="{= !${dash>/ui/dataLoaded} &amp;&amp; ${dash>/user/isValid} &amp;&amp; !${dash>/user/isLoading} }"
            alignItems="Center"
            justifyContent="Center"
            height="370px"
            class="sapUiTinyMarginTop filterArea">
            <core:Icon id="dash_Icon2" src="sap-icon://chart-table-view" size="4rem" color="#c2c2c2" class="sapUiSmallMarginBottom"/>
            <Title id="dash_Title5" text="No Data Loaded" level="H4"/>
            <Text id="dash_Text2"
                text="Select filter criteria above and click 'Go' to load annual plans for validation."
                class="sapUiSmallMarginTop" textAlign="Center"/>
            <Button id="dash_Button8" text="Load All Plans" type="Emphasized"
                icon="sap-icon://search" press=".onApplyFilter" class="sapUiMediumMarginTop"/>
        </VBox>

        <!-- Data Table -->
        <VBox class="filterArea" visible="{dash>/ui/dataLoaded}">

            <Toolbar id="dash_Toolbar3">
                <Title id="dash_Title6" text="Annual Plans – Detailed View" level="H4"/>
                <ObjectStatus id="dash_ObjectStatus16"
                    text="{= ${dash>/filteredRows}.length + ' plan(s)'}"
                    state="Information" class="sapUiSmallMarginBegin"/>
                <ObjectStatus id="violationBadge"
                    text="{dash>/kpiSummary/violatingPlans} violation(s)"
                    state="{= ${dash>/kpiSummary/violatingPlans} > 0 ? 'Error' : 'Success'}"
                    icon="{= ${dash>/kpiSummary/violatingPlans} > 0 ? 'sap-icon://error' : 'sap-icon://accept'}"
                    class="sapUiSmallMarginBegin"/>
                <ToolbarSpacer id="dash_ToolbarSpacer6"/>
                <Button text="Approve Selected" type="Accept" icon="sap-icon://sys-enter-2" press=".onBulkApprove" class="sapUiTinyMarginEnd"/>
                <Button text="Reject Selected"  type="Reject" icon="sap-icon://sys-cancel-2" press=".onBulkReject"/>
                <Label id="dash_Label40" text="Group by:" design="Bold" class="sapUiSmallMarginEnd"/>
                <Select id="selGroupBy" width="150px" change=".onGroupByChange">
                    <items>
                        <core:Item id="dash_Item25" key=""            text="No Grouping"  />
                        <core:Item id="dash_Item26" key="salesOffice" text="Sales Office" />
                        <core:Item id="dash_Item27" key="material"    text="Material"     />
                        <core:Item id="dash_Item28" key="industry"    text="Industry"     />
                    </items>
                </Select>
            </Toolbar>

            <table:Table
                id="dashTable"
                rows="{dash>/filteredRows}"
                selectionMode="MultiToggle"
                alternateRowColors="true"
                visibleRowCount="6"
                rowHeight="44"
                enableBusyIndicator="true"
                busy="{dash>/ui/busy}"
                visible="{dash>/ui/dataLoaded}"
                fixedColumnCount="2"
                class="sapUiSmallMarginTop zonalPlanTable">

                <!-- Customer -->
                <table:Column id="dash_Column26" width="13rem" label="Customer" sortProperty="customer" filterProperty="customer">
                    <Label id="dash_Label41" text="Customer"/>
                    <table:template>
                        <VBox id="dash_VBox4">
                            <Link id="dash_Link" text="{dash>customer}" press=".onCustomerDrillDown" wrapping="false"/>
                            <Text id="dash_Text3" text="{dash>salesOffice}" wrapping="false"/>
                        </VBox>
                    </table:template>
                </table:Column>

                <!-- Contract -->
                <table:Column id="dash_Column27" width="11rem" label="Contract" sortProperty="contract">
                    <Label id="dash_Label42" text="Contract"/>
                    <table:template>
                        <VBox id="dash_VBox5">
                            <Text id="dash_Text4" text="{dash>contract}" wrapping="false"/>
                            <ObjectStatus id="dash_ObjectStatus17" text="{dash>material}" state="Information"/>
                        </VBox>
                    </table:template>
                </table:Column>

                <!-- Industry -->
                <table:Column id="dash_Column28" width="9rem" label="Industry" sortProperty="industry">
                    <Label id="dash_Label43" text="Industry"/>
                    <table:template>
                        <Text id="dash_Text5" text="{dash>industry}" wrapping="false"/>
                    </table:template>
                </table:Column>

                <!-- AACQ -->
                <table:Column id="dash_Column29" width="8rem" hAlign="End" label="AACQ">
                    <Label id="dash_Label44" text="AACQ"/>
                    <table:template>
                        <ObjectNumber id="dash_ObjectNumber" number="{dash>aacq}" unit="MBT" emphasized="false"/>
                    </table:template>
                </table:Column>

                <!-- Jan -->
                <table:Column id="dash_Column30" width="5.5rem" hAlign="Center" label="Jan">
                    <Label id="dash_Label45" text="Jan"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus18" text="{dash>jan}"
                            state="{path: 'dash>janState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Feb -->
                <table:Column id="dash_Column31" width="5.5rem" hAlign="Center" label="Feb">
                    <Label id="dash_Label46" text="Feb"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus19" text="{dash>feb}"
                            state="{path: 'dash>febState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Mar -->
                <table:Column id="dash_Column32" width="5.5rem" hAlign="Center" label="Mar">
                    <Label id="dash_Label47" text="Mar"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus20" text="{dash>mar}"
                            state="{path: 'dash>marState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Q1 Total -->
                <table:Column id="dash_Column33" width="7rem" hAlign="Center" label="Q1 Total">
                    <Label id="dash_Label48" text="Q1 Total"/>
                    <table:template>
                        <VBox id="dash_VBox8" alignItems="Center">
                            <ObjectStatus id="dash_ObjectStatus21"
                                text="{dash>q1}"
                                state="{path: 'dash>q1State', formatter: '.formatState'}"
                                icon="{path: 'dash>q1State', formatter: '.formatStateIcon'}"/>
                            <Text id="dash_Text35" text="Limit: {dash>q1Limit}%"/>
                        </VBox>
                    </table:template>
                </table:Column>

                <!-- Apr -->
                <table:Column id="dash_Column34" width="5.5rem" hAlign="Center" label="Apr">
                    <Label id="dash_Label49" text="Apr"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus22" text="{dash>apr}"
                            state="{path: 'dash>aprState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- May -->
                <table:Column id="dash_Column35" width="5.5rem" hAlign="Center" label="May">
                    <Label id="dash_Label50" text="May"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus23" text="{dash>may}"
                            state="{path: 'dash>mayState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Jun -->
                <table:Column id="dash_Column36" width="5.5rem" hAlign="Center" label="Jun">
                    <Label id="dash_Label51" text="Jun"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus24" text="{dash>jun}"
                            state="{path: 'dash>junState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Q2 Total -->
                <table:Column id="dash_Column37" width="7rem" hAlign="Center" label="Q2 Total">
                    <Label id="dash_Label52" text="Q2 Total"/>
                    <table:template>
                        <VBox id="dash_VBox9" alignItems="Center">
                            <ObjectStatus id="dash_ObjectStatus25"
                                text="{dash>q2}"
                                state="{path: 'dash>q2State', formatter: '.formatState'}"
                                icon="{path: 'dash>q2State', formatter: '.formatStateIcon'}"/>
                            <Text id="dash_Text36" text="Limit: {dash>q2Limit}%"/>
                        </VBox>
                    </table:template>
                </table:Column>

                <!-- Jul -->
                <table:Column id="dash_Column38" width="5.5rem" hAlign="Center" label="Jul">
                    <Label id="dash_Label53" text="Jul"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus26" text="{dash>jul}"
                            state="{path: 'dash>julState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Aug -->
                <table:Column id="dash_Column39" width="5.5rem" hAlign="Center" label="Aug">
                    <Label id="dash_Label54" text="Aug"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus27" text="{dash>aug}"
                            state="{path: 'dash>augState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Sep -->
                <table:Column id="dash_Column40" width="5.5rem" hAlign="Center" label="Sep">
                    <Label id="dash_Label55" text="Sep"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus28" text="{dash>sep}"
                            state="{path: 'dash>sepState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Q3 Total -->
                <table:Column id="dash_Column41" width="7rem" hAlign="Center" label="Q3 Total">
                    <Label id="dash_Label56" text="Q3 Total"/>
                    <table:template>
                        <VBox id="dash_VBox10" alignItems="Center">
                            <ObjectStatus id="dash_ObjectStatus29"
                                text="{dash>q3}"
                                state="{path: 'dash>q3State', formatter: '.formatState'}"
                                icon="{path: 'dash>q3State', formatter: '.formatStateIcon'}"/>
                            <Text id="dash_Text37" text="Limit: {dash>q3Limit}%"/>
                        </VBox>
                    </table:template>
                </table:Column>

                <!-- Oct -->
                <table:Column id="dash_Column42" width="5.5rem" hAlign="Center" label="Oct">
                    <Label id="dash_Label57" text="Oct"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus30" text="{dash>oct}"
                            state="{path: 'dash>octState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Nov -->
                <table:Column id="dash_Column43" width="5.5rem" hAlign="Center" label="Nov">
                    <Label id="dash_Label58" text="Nov"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus31" text="{dash>nov}"
                            state="{path: 'dash>novState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Dec -->
                <table:Column id="dash_Column44" width="5.5rem" hAlign="Center" label="Dec">
                    <Label id="dash_Label59" text="Dec"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus32" text="{dash>dec}"
                            state="{path: 'dash>decState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

                <!-- Q4 Total -->
                <table:Column id="dash_Column45" width="7rem" hAlign="Center" label="Q4 Total">
                    <Label id="dash_Label60" text="Q4 Total"/>
                    <table:template>
                        <VBox id="dash_VBox11" alignItems="Center">
                            <ObjectStatus id="dash_ObjectStatus33"
                                text="{dash>q4}"
                                state="{path: 'dash>q4State', formatter: '.formatState'}"
                                icon="{path: 'dash>q4State', formatter: '.formatStateIcon'}"/>
                            <Text id="dash_Text38" text="Limit: {dash>q4Limit}%"/>
                        </VBox>
                    </table:template>
                </table:Column>

                <!-- Annual Total -->
                <table:Column id="dash_Column46" width="8rem" hAlign="Center" label="Annual Total">
                    <Label id="dash_Label61" text="Annual Total"/>
                    <table:template>
                        <ObjectStatus id="dash_ObjectStatus34"
                            text="{dash>annual}"
                            state="{path: 'dash>annualState', formatter: '.formatState'}"/>
                    </table:template>
                </table:Column>

              <!-- status column -->
                <table:Column width="8rem" hAlign="Center" label="Status">
                    <Label text="Status"/>
                    <table:template>
                        <ObjectStatus
                            text="{dash>approvalStatus}"
                            state="{dash>approvalState}"/>
                    </table:template>
                </table:Column>

                <!-- Actions -->
                <table:Column id="dash_Column96" width="30rem" hAlign="Center" label="Actions">
                    <Label id="dash_Label91" text="Actions"/>
                    <table:template>
                        <HBox>
                            <Button id="zonal_Butto7" text="View" type="Ghost"
                                icon="sap-icon://detail-view" press=".onCustomerDrillDown"
                                class="sapUiTinyMarginEnd"/>
<Button
    text="Edit"
    icon="sap-icon://edit"
    type="Ghost"
    press="onEditPlan"
    class="sapUiTinyMarginEnd"
    visible="{= ${dash>/user/level} &lt;= 2 &amp;&amp; ${dash>approvalStatus} === 'Pending' }"/>
<Button
    text="Reduction"
    icon="sap-icon://trend-down"
    type="Critical"
    press="onPressReductionBtn"
    class="sapUiTinyMarginEnd"
    visible="{= ${dash>/user/level} &gt;= 3 &amp;&amp; ${dash>approvalStatus} === 'Pending' }"/>
<Button
    text="Review &amp; Approve"
    icon="sap-icon://sys-enter-2"
    type="Accept"
    press="onOpenViewDialog"
    class="sapUiTinyMarginEnd"
    visible="{!= ${dash>approvalStatus} === 'Reject' }"/>

                            </HBox>
                    </table:template>
                </table:Column>

            </table:Table>

            <MessageStrip
                id="violationStrip"
                text="⚠ {dash>/kpiSummary/violatingPlans} plan(s) have quarterly percentage violations. Review highlighted cells (🔴 Red = Exceeded, 🟡 Amber = Near limit, 🟢 Green = Compliant)."
                type="Warning"
                showIcon="true"
                showCloseButton="true"
                visible="{= ${dash>/ui/dataLoaded} &amp;&amp; ${dash>/kpiSummary/violatingPlans} > 0}"
                class="sapUiSmallMarginTop"/>

        </VBox>

     </ScrollContainer>
</Page>
</mvc:View>